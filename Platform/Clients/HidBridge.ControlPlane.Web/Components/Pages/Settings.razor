@page "/settings"
@attribute [Authorize(Policy = OperatorPolicies.Viewer)]
@implements IAsyncDisposable
@inject OperatorText T
@inject OperatorAuthDescriptor Auth
@inject OperatorIdentityContext Identity
@inject Microsoft.Extensions.Options.IOptions<HidBridge.ControlPlane.Web.Configuration.ControlPlaneApiOptions> ApiOptions
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@inject IJSRuntime Js

<PageTitle>@T["NavSettings"]</PageTitle>

<section class="hid-page">
    <div class="hid-page-heading">
        <p class="hid-section-kicker">@T["NavSettings"]</p>
        <h2 class="hid-section-title">@T["SettingsTitle"]</h2>
        <p class="hid-section-subtitle">@T["SettingsSubtitle"]</p>
    </div>

    <div class="hid-settings-grid">
        <section class="hid-settings-section">
            <div>
                <h3 class="hid-card-title">@T["LanguagePreference"]</h3>
                <p class="hid-card-subtitle">@T["LanguagePreferenceHelp"]</p>
            </div>

            <div class="hid-choice-grid">
                @foreach (var option in T.SupportedCultures)
                {
                    var isActive = string.Equals(option.Code, T.CurrentCultureCode, StringComparison.OrdinalIgnoreCase);
                    <a class="hid-choice-card @(isActive ? "hid-choice-card--active" : null)"
                       href="@BuildCultureUrl(option.Code)">
                        <div class="hid-choice-card-head">
                            <div>
                                <div class="hid-choice-title">@option.DisplayName</div>
                                <div class="hid-choice-card-note">@option.Code</div>
                            </div>
                            @if (isActive)
                            {
                                <span class="hid-badge hid-badge--positive">@T["Active"]</span>
                            }
                        </div>
                    </a>
                }

                <a class="hid-choice-card" href="@BuildClearCultureUrl()">
                    <div class="hid-choice-title">@T["UseBrowserLanguage"]</div>
                    <div class="hid-choice-card-note">@T["DetectedFromBrowser"]</div>
                </a>
            </div>

            <div class="hid-subtle-copy">@T["SavePreferenceHelp"]</div>
        </section>

        <section class="hid-settings-section">
            <div>
                <h3 class="hid-card-title">@T["ThemePreference"]</h3>
                <p class="hid-card-subtitle">@T["ThemePreferenceHelp"]</p>
            </div>

            <div class="hid-choice-grid">
                @foreach (var option in ThemeOptions)
                {
                    var isActive = string.Equals(option.Code, _themePreference, StringComparison.OrdinalIgnoreCase);
                    <a class="hid-choice-card @(isActive ? "hid-choice-card--active" : null)"
                       href="@BuildThemeUrl(option.Code)">
                        <div class="hid-choice-card-head">
                            <div>
                                <div class="hid-choice-title">@option.Title</div>
                                <div class="hid-choice-card-note">@option.Description</div>
                            </div>
                            @if (isActive)
                            {
                                <span class="hid-badge hid-badge--positive">@T["Active"]</span>
                            }
                        </div>
                    </a>
                }
            </div>

            <div class="hid-theme-indicator">
                <span class="hid-theme-swatch" aria-hidden="true"></span>
                <span>@T["CurrentTheme"]: @_themePreference</span>
            </div>
        </section>

        <section class="hid-settings-section">
            <div>
                <h3 class="hid-card-title">@T["AgentProfileTitle"]</h3>
                <p class="hid-card-subtitle">@T["AgentProfileSubtitle"]</p>
            </div>

            <div class="hid-choice-grid">
                @foreach (var option in AgentLatencyProfiles)
                {
                    var isActive = string.Equals(option.Code, _agentProfile.FfmpegLatencyProfile, StringComparison.OrdinalIgnoreCase);
                    <button type="button"
                            class="hid-choice-card @(isActive ? "hid-choice-card--active" : null)"
                            @onclick="() => SelectLatencyProfile(option.Code)">
                        <div class="hid-choice-card-head">
                            <div>
                                <div class="hid-choice-title">@option.Title</div>
                                <div class="hid-choice-card-note">@option.Description</div>
                            </div>
                            @if (isActive)
                            {
                                <span class="hid-badge hid-badge--positive">@T["Active"]</span>
                            }
                        </div>
                    </button>
                }
            </div>

            <div class="hid-choice-grid">
                <label class="hid-field-label">
                    @T["AgentProfileStreamId"]
                    <input class="hid-input" @bind="_agentProfile.MediaStreamId" @bind:event="oninput" />
                </label>
                <label class="hid-field-label">
                    @T["AgentProfileMediaHost"]
                    <input class="hid-input" @bind="_agentProfile.MediaHostBaseUrl" @bind:event="oninput" />
                </label>
                <label class="hid-field-label">
                    @T["AgentProfileMediaHealthUrl"]
                    <input class="hid-input" @bind="_agentProfile.MediaHealthUrl" @bind:event="oninput" />
                </label>
                <label class="hid-field-label">
                    @T["AgentProfileUartPort"]
                    <input class="hid-input" @bind="_agentProfile.UartPort" @bind:event="oninput" />
                </label>
                <label class="hid-field-label">
                    @T["AgentProfileUartHmacKey"]
                    <input class="hid-input" @bind="_agentProfile.UartHmacKey" @bind:event="oninput" />
                </label>
                <label class="hid-field-label">
                    @T["AgentProfileVideoDevice"]
                    <input class="hid-input" @bind="_agentProfile.FfmpegVideoDevice" @bind:event="oninput" />
                </label>
                <label class="hid-field-label">
                    @T["AgentProfileAudioDevice"]
                    <input class="hid-input" @bind="_agentProfile.FfmpegAudioDevice" @bind:event="oninput" />
                </label>
                <label class="hid-field-label">
                    @T["AgentProfileFfmpegExecutablePath"]
                    <input class="hid-input" @bind="_agentProfile.FfmpegExecutablePath" @bind:event="oninput" />
                </label>
                <label class="hid-field">
                    <input type="checkbox" @bind="_agentProfile.FfmpegUseTestSource" />
                    <span>@T["AgentProfileUseTestSource"]</span>
                </label>
                <label class="hid-field">
                    <input type="checkbox" @bind="_agentProfile.MediaBackendAutoStart" />
                    <span>@T["AgentProfileMediaBackendAutoStart"]</span>
                </label>
                <label class="hid-field">
                    <input type="checkbox" @bind="_agentProfile.RequireMediaReady" />
                    <span>@T["AgentProfileRequireMediaReady"]</span>
                </label>
            </div>

            <div class="hid-candidate-actions">
                <button class="hid-button-primary hid-button-sm" type="button" @onclick="SaveAgentProfileAsync">@T["AgentProfileSave"]</button>
                <button class="hid-button-secondary hid-button-sm" type="button" @onclick="ResetAgentProfileAsync">@T["AgentProfileReset"]</button>
            </div>
            @if (!string.IsNullOrWhiteSpace(_agentProfileStatus))
            {
                <div class="hid-subtle-copy">@_agentProfileStatus</div>
            }

            <div class="hid-field-label">
                @T["AgentProfileGeneratedCommand"]
                <textarea class="hid-input" rows="7" readonly>@BuildRuntimeCtlCommand()</textarea>
            </div>
            <div class="hid-candidate-actions">
                <button class="hid-button-secondary hid-button-sm" type="button" @onclick="CopyRuntimeCtlCommandAsync">@T["AgentProfileCopyCommand"]</button>
            </div>
            <div class="hid-subtle-copy">@T["AgentProfileCommandHint"]</div>

            <div class="hid-field-label">
                @T["AgentProfileGeneratedAcceptanceCommand"]
                <textarea class="hid-input" rows="7" readonly>@BuildAcceptanceCommand()</textarea>
            </div>
            <div class="hid-candidate-actions">
                <button class="hid-button-secondary hid-button-sm" type="button" @onclick="CopyAcceptanceCommandAsync">@T["AgentProfileCopyCommand"]</button>
            </div>
            <div class="hid-subtle-copy">@T["AgentProfileAcceptanceHint"]</div>
        </section>
    </div>

    <section class="hid-settings-grid">
        <div class="hid-detail-card">
            <div class="hid-detail-label">@T["CurrentCulture"]</div>
            <div class="hid-detail-value">@T.CurrentCultureCode</div>
        </div>
        <div class="hid-detail-card">
            <div class="hid-detail-label">@T["ApiBaseUrl"]</div>
            <div class="hid-detail-value">@ApiOptions.Value.BaseUrl</div>
            <div class="hid-meta-note">@T["OperatorPrincipalSetting"]: @ApiOptions.Value.OperatorPrincipalId</div>
        </div>
        <div class="hid-detail-card">
            <div class="hid-detail-label">@T["IdentityAccessPanel"]</div>
            <div class="hid-detail-value">@Identity.DisplayName</div>
            <div class="hid-meta-note">@T["CurrentOperator"]: @Identity.PrincipalId</div>
            <div class="hid-meta-note">@T["UserId"]: @Identity.SubjectId</div>
            <div class="hid-meta-note">@T["UserAddedAt"]: @FormatUserCreatedAt(Identity.UserCreatedAtUtc)</div>
            <div class="hid-meta-note">@T["Tenant"]: @Identity.TenantId</div>
            <div class="hid-meta-note">@T["Organization"]: @Identity.OrganizationId</div>
            <div class="hid-meta-note">@T["Roles"]: @Identity.RoleSummary</div>
            <div class="hid-meta-note">@T["AuthenticationMode"]: @Auth.Mode / @Identity.AuthenticationMode</div>
            <div class="hid-meta-note">@T["IdentityProvider"]: @Auth.ProviderDisplayName</div>
            <div class="hid-meta-note">@T["LoginPath"]: @Auth.LoginPath</div>
            <div class="hid-meta-note">@T["LogoutPath"]: @Auth.LogoutPath</div>
            <div class="hid-meta-note">@T["CallbackPath"]: @Auth.CallbackPath</div>
            <div class="hid-meta-note">@T["ThemeSwitchIssueDeferred"]</div>
        </div>
    </section>
</section>

@code {
    private string _themePreference = "auto";
    private IJSObjectReference? _settingsModule;
    private AgentProfileSettings _agentProfile = AgentProfileSettings.CreateDefault();
    private string? _agentProfileStatus;
    private const string AgentProfileStorageKey = "hidbridge.agentProfile.v1";

    private IReadOnlyList<ThemeOption> ThemeOptions =>
    [
        new("auto", T["ThemeAuto"], T["ThemeAutoHelp"]),
        new("light", T["ThemeLight"], T["ThemeLightHelp"]),
        new("dark", T["ThemeDark"], T["ThemeDarkHelp"]),
    ];

    private IReadOnlyList<ThemeOption> AgentLatencyProfiles =>
    [
        new("balanced", T["AgentProfileLatencyBalanced"], T["AgentProfileLatencyBalancedHelp"]),
        new("ultra", T["AgentProfileLatencyUltra"], T["AgentProfileLatencyUltraHelp"]),
        new("extreme", T["AgentProfileLatencyExtreme"], T["AgentProfileLatencyExtremeHelp"]),
    ];

    protected override void OnInitialized()
    {
        _themePreference = HttpContextAccessor.HttpContext?.Request.Cookies["hidbridge_theme"] ?? "auto";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            _settingsModule = await Js.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/Settings.razor.js");
            var stored = await _settingsModule.InvokeAsync<AgentProfileSettings?>("loadAgentProfile", AgentProfileStorageKey);
            if (stored is not null)
            {
                _agentProfile = stored.Normalize();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
            _settingsModule = null;
            _agentProfileStatus = T["AgentProfileLoadFailed"];
            await InvokeAsync(StateHasChanged);
        }
    }

    private string BuildCultureUrl(string culture)
        => $"/culture/set?culture={Uri.EscapeDataString(culture)}&redirectUri={Uri.EscapeDataString(Navigation.ToBaseRelativePath(Navigation.Uri) is { Length: > 0 } relative ? "/" + relative : "/settings")}";

    private string BuildClearCultureUrl()
        => $"/culture/clear?redirectUri={Uri.EscapeDataString(Navigation.ToBaseRelativePath(Navigation.Uri) is { Length: > 0 } relative ? "/" + relative : "/settings")}";

    private string BuildThemeUrl(string theme)
        => $"/theme/set?theme={Uri.EscapeDataString(theme)}&redirectUri={Uri.EscapeDataString(Navigation.ToBaseRelativePath(Navigation.Uri) is { Length: > 0 } relative ? "/" + relative : "/settings")}";

    private string FormatUserCreatedAt(DateTimeOffset? value)
        => value?.ToString("yyyy-MM-dd HH:mm:ss zzz") ?? T["NotAvailable"];

    private void SelectLatencyProfile(string profileCode)
    {
        _agentProfile.FfmpegLatencyProfile = profileCode;
    }

    private async Task SaveAgentProfileAsync()
    {
        _agentProfile = _agentProfile.Normalize();
        if (_settingsModule is null)
        {
            _agentProfileStatus = T["AgentProfileSaveFailed"];
            return;
        }

        try
        {
            var saved = await _settingsModule.InvokeAsync<bool>("saveAgentProfile", AgentProfileStorageKey, _agentProfile);
            _agentProfileStatus = saved ? T["AgentProfileSaved"] : T["AgentProfileSaveFailed"];
        }
        catch
        {
            _agentProfileStatus = T["AgentProfileSaveFailed"];
        }
    }

    private async Task ResetAgentProfileAsync()
    {
        _agentProfile = AgentProfileSettings.CreateDefault();
        await SaveAgentProfileAsync();
        await InvokeAsync(StateHasChanged);
    }

    private string BuildRuntimeCtlCommand()
    {
        var profile = _agentProfile.Normalize();
        var envParts = new List<string>
        {
            $"$env:HIDBRIDGE_EDGE_PROXY_MEDIAHEALTHURL={QuotePowerShell(profile.MediaHealthUrl)}",
            $"$env:HIDBRIDGE_EDGE_PROXY_REQUIREMEDIAREADY={QuotePowerShell(profile.RequireMediaReady ? "true" : "false")}",
        };

        var commandParts = new List<string>
        {
            "dotnet run --project Platform/Tools/HidBridge.RuntimeCtl/HidBridge.RuntimeCtl.csproj -- --platform-root Platform webrtc-stack",
            "-StopExisting",
            "-CommandExecutor uart",
            $"-UartPort {QuotePowerShell(profile.UartPort)}",
            $"-UartHmacKey {QuotePowerShell(profile.UartHmacKey)}",
            $"-FfmpegLatencyProfile {QuotePowerShell(profile.FfmpegLatencyProfile)}",
            $"-MediaStreamId {QuotePowerShell(profile.MediaStreamId)}",
            $"-MediaWhipUrl {QuotePowerShell(profile.BuildWhipUrl())}",
            $"-MediaWhepUrl {QuotePowerShell(profile.BuildWhepUrl())}",
            $"-MediaPlaybackUrl {QuotePowerShell(profile.BuildPlaybackUrl())}",
            $"-MediaBackendAutoStart {(profile.MediaBackendAutoStart ? "true" : "false")}",
            $"-FfmpegUseTestSource {(profile.FfmpegUseTestSource ? "true" : "false")}",
            $"-FfmpegExecutablePath {QuotePowerShell(profile.FfmpegExecutablePath)}",
        };

        if (!profile.FfmpegUseTestSource && !string.IsNullOrWhiteSpace(profile.FfmpegVideoDevice))
        {
            commandParts.Add($"-FfmpegVideoDevice {QuotePowerShell(profile.FfmpegVideoDevice)}");
        }

        if (!profile.FfmpegUseTestSource && !string.IsNullOrWhiteSpace(profile.FfmpegAudioDevice))
        {
            commandParts.Add($"-FfmpegAudioDevice {QuotePowerShell(profile.FfmpegAudioDevice)}");
        }

        return $"{string.Join("; ", envParts)}; {string.Join(" ", commandParts)}";
    }

    private string BuildAcceptanceCommand()
    {
        var profile = _agentProfile.Normalize();
        var commandParts = new List<string>
        {
            "dotnet run --project Platform/Tools/HidBridge.RuntimeCtl/HidBridge.RuntimeCtl.csproj -- --platform-root Platform webrtc-acceptance",
            "-CommandExecutor uart",
            "-SkipRuntimeBootstrap",
            "-StopExisting",
            "-StopStackAfter",
            "-PeerReadyTimeoutSec 45",
            "-MaxDurationSec 420",
            profile.RequireMediaReady ? "-RequireMediaReady" : string.Empty,
            "-RequireMediaPlaybackUrl",
            $"-UartPort {QuotePowerShell(profile.UartPort)}",
            $"-UartHmacKey {QuotePowerShell(profile.UartHmacKey)}",
            $"-MediaWhipUrl {QuotePowerShell(profile.BuildWhipUrl())}",
            $"-MediaWhepUrl {QuotePowerShell(profile.BuildWhepUrl())}",
            $"-MediaPlaybackUrl {QuotePowerShell(profile.BuildPlaybackUrl())}",
            $"-MediaHealthUrl {QuotePowerShell(profile.MediaHealthUrl)}",
        };

        return string.Join(" ", commandParts.Where(static part => !string.IsNullOrWhiteSpace(part)));
    }

    private async Task CopyRuntimeCtlCommandAsync()
        => await CopyCommandAsync(BuildRuntimeCtlCommand());

    private async Task CopyAcceptanceCommandAsync()
        => await CopyCommandAsync(BuildAcceptanceCommand());

    private async Task CopyCommandAsync(string command)
    {
        if (_settingsModule is null)
        {
            _agentProfileStatus = T["AgentProfileSaveFailed"];
            return;
        }

        try
        {
            var copied = await _settingsModule.InvokeAsync<bool>("copyTextToClipboard", command);
            _agentProfileStatus = copied ? T["AgentProfileCommandCopied"] : T["AgentProfileCopyFailed"];
        }
        catch
        {
            _agentProfileStatus = T["AgentProfileCopyFailed"];
        }
    }

    private static string QuotePowerShell(string value)
    {
        var normalized = value?.Trim() ?? string.Empty;
        return $"'{normalized.Replace("'", "''", StringComparison.Ordinal)}'";
    }

    public async ValueTask DisposeAsync()
    {
        if (_settingsModule is not null)
        {
            try
            {
                await _settingsModule.DisposeAsync();
            }
            catch
            {
                // Ignore module disposal failures during navigation shutdown.
            }
        }
    }

    private sealed record ThemeOption(string Code, string Title, string Description);

    private sealed class AgentProfileSettings
    {
        public string FfmpegLatencyProfile { get; set; } = "balanced";
        public string MediaHostBaseUrl { get; set; } = "http://127.0.0.1:19851";
        public string MediaHealthUrl { get; set; } = "http://127.0.0.1:18081/api/v1/versions";
        public string MediaStreamId { get; set; } = "edge-main";
        public string UartPort { get; set; } = "COM6";
        public string UartHmacKey { get; set; } = "your-master-secret";
        public string FfmpegExecutablePath { get; set; } = "ffmpeg";
        public string FfmpegVideoDevice { get; set; } = string.Empty;
        public string FfmpegAudioDevice { get; set; } = string.Empty;
        public bool FfmpegUseTestSource { get; set; }
        public bool MediaBackendAutoStart { get; set; }
        public bool RequireMediaReady { get; set; } = true;

        public static AgentProfileSettings CreateDefault() => new();

        public AgentProfileSettings Normalize()
        {
            var normalizedProfile = string.IsNullOrWhiteSpace(FfmpegLatencyProfile)
                ? "balanced"
                : FfmpegLatencyProfile.Trim().ToLowerInvariant();
            if (normalizedProfile is not ("balanced" or "ultra" or "extreme"))
            {
                normalizedProfile = "balanced";
            }

            var normalizedHost = string.IsNullOrWhiteSpace(MediaHostBaseUrl)
                ? "http://127.0.0.1:19851"
                : MediaHostBaseUrl.Trim().TrimEnd('/');

            return new AgentProfileSettings
            {
                FfmpegLatencyProfile = normalizedProfile,
                MediaHostBaseUrl = normalizedHost,
                MediaHealthUrl = string.IsNullOrWhiteSpace(MediaHealthUrl) ? "http://127.0.0.1:18081/api/v1/versions" : MediaHealthUrl.Trim(),
                MediaStreamId = string.IsNullOrWhiteSpace(MediaStreamId) ? "edge-main" : MediaStreamId.Trim(),
                UartPort = string.IsNullOrWhiteSpace(UartPort) ? "COM6" : UartPort.Trim(),
                UartHmacKey = string.IsNullOrWhiteSpace(UartHmacKey) ? "your-master-secret" : UartHmacKey.Trim(),
                FfmpegExecutablePath = string.IsNullOrWhiteSpace(FfmpegExecutablePath) ? "ffmpeg" : FfmpegExecutablePath.Trim(),
                FfmpegVideoDevice = (FfmpegVideoDevice ?? string.Empty).Trim(),
                FfmpegAudioDevice = (FfmpegAudioDevice ?? string.Empty).Trim(),
                FfmpegUseTestSource = FfmpegUseTestSource,
                MediaBackendAutoStart = MediaBackendAutoStart,
                RequireMediaReady = RequireMediaReady,
            };
        }

        public string BuildWhipUrl()
            => $"{MediaHostBaseUrl.TrimEnd('/')}/rtc/v1/whip/?app=live&stream={Uri.EscapeDataString(MediaStreamId)}";

        public string BuildWhepUrl()
            => $"{MediaHostBaseUrl.TrimEnd('/')}/rtc/v1/whep/?app=live&stream={Uri.EscapeDataString(MediaStreamId)}";

        public string BuildPlaybackUrl() => BuildWhepUrl();
    }
}
