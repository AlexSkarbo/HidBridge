@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime Js
@inject OperatorText T

<div class="hid-card-soft">
    <div class="hid-panel-toolbar">
        <div>
            <h4 class="hid-card-title">@T["MediaPanelTitle"]</h4>
            <p class="hid-card-subtitle">@T["MediaPanelSubtitle"]</p>
        </div>
        <div class="hid-candidate-actions">
            <button class="hid-button-secondary hid-button-sm"
                    disabled="@(_busy || string.IsNullOrWhiteSpace(PlaybackUrl) || _isRunning)"
                    @onclick="StartPlaybackAsync">
                @T["MediaStartStream"]
            </button>
            <button class="hid-button-secondary hid-button-sm"
                    disabled="@(_busy || !_isRunning)"
                    @onclick="StopPlaybackAsync">
                @T["MediaStopStream"]
            </button>
            <button class="hid-button-secondary hid-button-sm"
                    disabled="@(_busy || string.IsNullOrWhiteSpace(PlaybackUrl))"
                    @onclick="RestartPlaybackAsync">
                @T["MediaReconnectNow"]
            </button>
        </div>
    </div>

    <div class="hid-inline-meta">
        <span>@T["TransportMediaStreamId"]: @(string.IsNullOrWhiteSpace(MediaStreamId) ? "—" : MediaStreamId)</span>
        <span>@T["TransportMediaState"]: @(string.IsNullOrWhiteSpace(MediaState) ? "—" : MediaState)</span>
        <span>@T["TransportMediaReady"]: @(MediaReady.HasValue ? (MediaReady.Value ? T["Yes"] : T["No"]) : "—")</span>
        <span>@T["MediaPlaybackMode"]: @(_mode ?? "—")</span>
    </div>

    <div class="hid-inline-meta">
        <label class="hid-field">
            <input type="checkbox" checked="@_muted" @onchange="OnMutedChanged" />
            <span>@T["MediaMuted"]</span>
        </label>
        <label class="hid-field">
            <input type="checkbox" checked="@_autoReconnect" @onchange="OnAutoReconnectChanged" />
            <span>@T["MediaAutoReconnect"]</span>
        </label>
        <span>@T["MediaPlaybackState"]: @(_isRunning ? T["MediaPlaybackRunning"] : T["MediaPlaybackStopped"])</span>
        <span>@T["MediaConnectionState"]: @(_connectionState ?? "—")</span>
        <span>@T["MediaIceState"]: @(_iceConnectionState ?? "—")</span>
    </div>

    <div class="hid-inline-meta">
        <span>@T["MediaTrackCount"]: @_trackCount</span>
        <span>@T["MediaReconnectAttempts"]: @_reconnectAttempts</span>
        <span>@T["MediaLastEvent"]: @GetLastEventLabel()</span>
    </div>

    @{
        var notPlayableReason = GetNotPlayableReason();
    }

    @if (!string.IsNullOrWhiteSpace(notPlayableReason))
    {
        <div class="hid-alert hid-alert--warning">@T["MediaNotPlayableReason"]: @notPlayableReason</div>
    }

    @if (!string.IsNullOrWhiteSpace(_error) && !string.Equals(_error, notPlayableReason, StringComparison.OrdinalIgnoreCase))
    {
        <div class="hid-meta-note">@T["MediaPlaybackError"]: @_error</div>
    }

    <video @ref="_videoElement" controls autoplay playsinline class="hid-media-player"></video>

    @if (string.IsNullOrWhiteSpace(PlaybackUrl))
    {
        <div class="hid-empty-state">@T["MediaPlaybackNotAvailable"]</div>
    }
</div>

@code {
    [Parameter]
    public string SessionId { get; set; } = string.Empty;

    [Parameter]
    public string? PlaybackUrl { get; set; }

    [Parameter]
    public bool? MediaReady { get; set; }

    [Parameter]
    public string? MediaState { get; set; }

    [Parameter]
    public string? MediaStreamId { get; set; }

    [Parameter]
    public bool? BackendReady { get; set; }

    [Parameter]
    public string? BackendReasonCode { get; set; }

    [Parameter]
    public string? BackendReason { get; set; }

    [Parameter]
    public string? BackendMediaFailureReason { get; set; }

    [Parameter]
    public bool AutoStartWhenReady { get; set; } = true;

    private IJSObjectReference? _module;
    private DotNetObjectReference<SessionMediaPanel>? _dotNetRef;
    private ElementReference _videoElement;
    private bool _busy;
    private bool _isRunning;
    private bool _muted = true;
    private bool _autoReconnect = true;
    private string? _mode;
    private string? _error;
    private string? _activePlaybackUrl;
    private string? _connectionState;
    private string? _iceConnectionState;
    private string? _lastEvent;
    private DateTimeOffset? _lastEventAtUtc;
    private int _trackCount;
    private int _reconnectAttempts;
    private const int ReconnectDelayMs = 1200;
    private const int MaxReconnectAttempts = 20;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            _module = await Js.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/SessionMediaPanel.razor.js");
            _dotNetRef = DotNetObjectReference.Create(this);

            var currentUrl = NormalizeUrl(PlaybackUrl);
            if (ShouldAutoStart(currentUrl))
            {
                await StartPlaybackInternalAsync(currentUrl);
            }
        }
        catch
        {
            _module = null;
            _error = "Media module failed to load.";
            StateHasChanged();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_isRunning || _module is null)
        {
            var autoUrl = NormalizeUrl(PlaybackUrl);
            if (_module is null || !ShouldAutoStart(autoUrl))
            {
                return;
            }

            await StartPlaybackInternalAsync(autoUrl);
            return;
        }

        var nextUrl = NormalizeUrl(PlaybackUrl);
        if (string.Equals(_activePlaybackUrl, nextUrl, StringComparison.Ordinal))
        {
            return;
        }

        await StartPlaybackInternalAsync(nextUrl);
    }

    private async Task StartPlaybackAsync()
    {
        await StartPlaybackInternalAsync(NormalizeUrl(PlaybackUrl));
    }

    private async Task RestartPlaybackAsync()
    {
        if (_busy)
        {
            return;
        }

        var nextUrl = NormalizeUrl(PlaybackUrl);
        if (string.IsNullOrWhiteSpace(nextUrl))
        {
            _error = T["MediaPlaybackNotAvailable"];
            return;
        }

        await StopPlaybackAsync();
        await StartPlaybackInternalAsync(nextUrl);
    }

    private async Task StartPlaybackInternalAsync(string? url)
    {
        if (_module is null)
        {
            _error = "Media module is unavailable.";
            return;
        }

        if (string.IsNullOrWhiteSpace(url))
        {
            _error = T["MediaPlaybackNotAvailable"];
            _isRunning = false;
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            var result = await _module.InvokeAsync<MediaPlaybackStartResult>(
                "startPlayback",
                _videoElement,
                url,
                _muted,
                _dotNetRef,
                new MediaPlaybackStartOptions
                {
                    AutoReconnect = _autoReconnect,
                    ReconnectDelayMs = ReconnectDelayMs,
                    MaxReconnectAttempts = MaxReconnectAttempts,
                });
            if (!result.Ok)
            {
                _error = string.IsNullOrWhiteSpace(result.Error) ? "Playback start failed." : result.Error;
                _isRunning = false;
                _mode = result.Mode;
                _activePlaybackUrl = null;
                _connectionState = result.ConnectionState;
                _iceConnectionState = result.IceConnectionState;
                return;
            }

            _isRunning = true;
            _mode = result.Mode;
            _activePlaybackUrl = url;
            _connectionState = result.ConnectionState;
            _iceConnectionState = result.IceConnectionState;
            _lastEvent = "started";
            _lastEventAtUtc = DateTimeOffset.UtcNow;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _isRunning = false;
            _mode = null;
            _activePlaybackUrl = null;
            _connectionState = null;
            _iceConnectionState = null;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task StopPlaybackAsync()
    {
        if (_module is null)
        {
            _isRunning = false;
            _activePlaybackUrl = null;
            _mode = null;
            return;
        }

        _busy = true;
        try
        {
            await _module.InvokeVoidAsync("stopPlayback", _videoElement);
            _isRunning = false;
            _activePlaybackUrl = null;
            _mode = null;
            _connectionState = null;
            _iceConnectionState = null;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task OnMutedChanged(ChangeEventArgs args)
    {
        var next = args.Value switch
        {
            bool value => value,
            string text when bool.TryParse(text, out var value) => value,
            _ => _muted,
        };

        _muted = next;
        if (_module is null)
        {
            return;
        }

        try
        {
            await _module.InvokeVoidAsync("setMuted", _videoElement, _muted);
        }
        catch
        {
            // Ignore mute toggle failures; playback remains active.
        }
    }

    private async Task OnAutoReconnectChanged(ChangeEventArgs args)
    {
        var next = args.Value switch
        {
            bool value => value,
            string text when bool.TryParse(text, out var value) => value,
            _ => _autoReconnect,
        };

        _autoReconnect = next;
        if (_module is null)
        {
            return;
        }

        try
        {
            await _module.InvokeVoidAsync(
                "setPlaybackOptions",
                _videoElement,
                new MediaPlaybackStartOptions
                {
                    AutoReconnect = _autoReconnect,
                    ReconnectDelayMs = ReconnectDelayMs,
                    MaxReconnectAttempts = MaxReconnectAttempts,
                });
        }
        catch
        {
            // Ignore option synchronization failures; current playback remains active.
        }
    }

    [JSInvokable]
    public Task OnPlaybackEvent(MediaPlaybackRuntimeEvent runtimeEvent)
    {
        if (runtimeEvent is null)
        {
            return Task.CompletedTask;
        }

        _lastEvent = runtimeEvent.Type;
        _lastEventAtUtc = DateTimeOffset.UtcNow;
        if (!string.IsNullOrWhiteSpace(runtimeEvent.Mode))
        {
            _mode = runtimeEvent.Mode;
        }

        if (!string.IsNullOrWhiteSpace(runtimeEvent.ConnectionState))
        {
            _connectionState = runtimeEvent.ConnectionState;
        }

        if (!string.IsNullOrWhiteSpace(runtimeEvent.IceConnectionState))
        {
            _iceConnectionState = runtimeEvent.IceConnectionState;
        }

        if (runtimeEvent.TrackCount.HasValue)
        {
            _trackCount = Math.Max(0, runtimeEvent.TrackCount.Value);
        }

        if (runtimeEvent.Attempt.HasValue)
        {
            _reconnectAttempts = Math.Max(_reconnectAttempts, runtimeEvent.Attempt.Value);
        }

        if (runtimeEvent.IsRunning.HasValue)
        {
            _isRunning = runtimeEvent.IsRunning.Value;
        }

        if (!string.IsNullOrWhiteSpace(runtimeEvent.Error))
        {
            _error = runtimeEvent.Error;
        }
        else if (string.Equals(runtimeEvent.Type, "started", StringComparison.OrdinalIgnoreCase)
            || string.Equals(runtimeEvent.Type, "reconnect-success", StringComparison.OrdinalIgnoreCase))
        {
            _error = null;
        }

        return InvokeAsync(StateHasChanged);
    }

    private bool ShouldAutoStart(string? playbackUrl)
    {
        if (!AutoStartWhenReady || _busy || _isRunning || string.IsNullOrWhiteSpace(playbackUrl))
        {
            return false;
        }

        if (MediaReady.HasValue)
        {
            return MediaReady.Value;
        }

        return string.Equals(MediaState, "Ready", StringComparison.OrdinalIgnoreCase)
            || string.Equals(MediaState, "Streaming", StringComparison.OrdinalIgnoreCase);
    }

    private string GetLastEventLabel()
    {
        if (string.IsNullOrWhiteSpace(_lastEvent))
        {
            return "—";
        }

        if (!_lastEventAtUtc.HasValue)
        {
            return _lastEvent!;
        }

        return $"{_lastEvent} ({_lastEventAtUtc.Value.LocalDateTime:HH:mm:ss})";
    }

    private string? GetNotPlayableReason()
    {
        var backendReason = GetBackendNotPlayableReason();
        if (!string.IsNullOrWhiteSpace(backendReason))
        {
            return backendReason;
        }

        if (!string.IsNullOrWhiteSpace(_error))
        {
            return _error;
        }

        if (string.IsNullOrWhiteSpace(PlaybackUrl))
        {
            return T["MediaPlaybackNotAvailable"];
        }

        return null;
    }

    private string? GetBackendNotPlayableReason()
    {
        if (BackendReady != false)
        {
            return null;
        }

        var readinessReason = NormalizeDiagnosticInput(BackendReason);
        var readinessCode = NormalizeDiagnosticInput(BackendReasonCode);
        if (!string.IsNullOrWhiteSpace(readinessReason) && !string.IsNullOrWhiteSpace(readinessCode))
        {
            return $"{readinessCode}: {readinessReason}";
        }

        if (!string.IsNullOrWhiteSpace(readinessReason))
        {
            return readinessReason;
        }

        if (!string.IsNullOrWhiteSpace(readinessCode))
        {
            return readinessCode;
        }

        var mediaFailure = NormalizeDiagnosticInput(BackendMediaFailureReason);
        if (!string.IsNullOrWhiteSpace(mediaFailure))
        {
            return mediaFailure;
        }

        var state = NormalizeDiagnosticInput(MediaState);
        if (!string.IsNullOrWhiteSpace(state) && !IsHealthyMediaState(state))
        {
            return $"media_state_unhealthy: {state}";
        }

        return null;
    }

    private static string? NormalizeDiagnosticInput(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        var normalized = value.Trim();
        return string.Equals(normalized, "—", StringComparison.Ordinal)
            ? null
            : normalized;
    }

    private static bool IsHealthyMediaState(string state)
        => string.Equals(state, "Ready", StringComparison.OrdinalIgnoreCase)
            || string.Equals(state, "Streaming", StringComparison.OrdinalIgnoreCase)
            || string.Equals(state, "Connected", StringComparison.OrdinalIgnoreCase)
            || string.Equals(state, "Healthy", StringComparison.OrdinalIgnoreCase);

    private static string? NormalizeUrl(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        return value.Trim();
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("stopPlayback", _videoElement);
            }
            catch
            {
            }

            try
            {
                await _module.DisposeAsync();
            }
            catch
            {
            }
        }

        _dotNetRef?.Dispose();
        _dotNetRef = null;
    }

    private sealed class MediaPlaybackStartResult
    {
        public bool Ok { get; set; }
        public string? Mode { get; set; }
        public string? Error { get; set; }
        public string? ConnectionState { get; set; }
        public string? IceConnectionState { get; set; }
    }

    private sealed class MediaPlaybackStartOptions
    {
        public bool AutoReconnect { get; set; } = true;
        public int ReconnectDelayMs { get; set; } = SessionMediaPanel.ReconnectDelayMs;
        public int MaxReconnectAttempts { get; set; } = SessionMediaPanel.MaxReconnectAttempts;
    }

    public sealed class MediaPlaybackRuntimeEvent
    {
        public string? Type { get; set; }
        public string? Mode { get; set; }
        public string? Error { get; set; }
        public string? ConnectionState { get; set; }
        public string? IceConnectionState { get; set; }
        public int? TrackCount { get; set; }
        public int? Attempt { get; set; }
        public bool? IsRunning { get; set; }
    }
}
