@page "/telemetry"
@attribute [Authorize(Policy = OperatorPolicies.Viewer)]
@inject HidBridge.ControlPlane.Web.Services.ControlPlaneApiClient ApiClient
@inject OperatorText T

<PageTitle>@T["NavTelemetryDashboard"]</PageTitle>

<section class="hid-page">
    <div class="hid-page-heading">
        <p class="hid-section-kicker">@T["TelemetryDashboardTitle"]</p>
        <h2 class="hid-section-title">@T["TelemetryDashboardTitle"]</h2>
        <p class="hid-section-subtitle">@T["TelemetryDashboardSubtitle"]</p>
    </div>

    @if (_denial is not null)
    {
        <AuthorizationDeniedPanel Denial="_denial" Title="@T["AccessDenied"]" />
    }
    else if (_backendUnavailableMessage is not null)
    {
        <BackendUnavailablePanel Message="@_backendUnavailableMessage" Title="@T["BackendUnavailable"]" Hint="@T["BackendUnavailableHint"]" />
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="hid-alert hid-alert--danger">@_error</div>
    }
    else if (_backendUnavailableMessage is null && _dashboard is null)
    {
        <div class="hid-card-soft hid-empty-state">@T["LoadingTelemetryDashboard"]</div>
    }
    else
    {
        var dashboard = _dashboard!;

        <div class="hid-stat-grid">
            <div class="hid-stat-card"><div class="hid-stat-label">@T["TotalEvents"]</div><div class="hid-stat-value">@dashboard.TotalEvents</div></div>
            <div class="hid-stat-card"><div class="hid-stat-label">@T["SessionScoped"]</div><div class="hid-stat-value">@dashboard.SessionScopedEvents</div></div>
            <div class="hid-stat-card"><div class="hid-stat-label">@T["Latest"]</div><div class="hid-detail-value">@FormatTime(dashboard.LatestEventAtUtc)</div></div>
        </div>

        <div class="hid-page-grid hid-page-grid--diagnostics">
            <section class="hid-section-block">
                <h3 class="hid-card-title">@T["Signals"]</h3>
                <div class="hid-list-stack">
                    @foreach (var signal in dashboard.Signals.Take(8))
                    {
                        <div class="hid-list-card">
                            <div class="hid-list-card-header">
                                <div>
                                    <div class="hid-list-title">@signal.Scope / @signal.MetricName</div>
                                    <div class="hid-list-subtitle">@signal.LatestAtUtc.ToLocalTime().ToString("HH:mm:ss")</div>
                                </div>
                                <div class="hid-list-side">@signal.LatestValue</div>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <section class="hid-section-block">
                <h3 class="hid-card-title">@T["SessionHealth"]</h3>
                <div class="hid-list-stack">
                    @foreach (var session in dashboard.Sessions.Take(8))
                    {
                        <div class="hid-list-card">
                            <div class="hid-list-card-header">
                                <div>
                                    <div class="hid-list-title">@session.SessionId</div>
                                    <div class="hid-list-subtitle">@T["Events"]: @session.EventCount</div>
                                </div>
                                <div class="hid-list-timestamp">@FormatTime(session.LatestEventAtUtc)</div>
                            </div>
                            <div class="hid-inline-meta">
                                @foreach (var metric in session.LatestMetrics.Take(4))
                                {
                                    <span class="hid-pill">@metric.Key: @metric.Value</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </section>
        </div>
    }
</section>

@code {
    private TelemetryDashboardViewModel? _dashboard;
    private string? _error;
    private AuthorizationDeniedViewModel? _denial;
    private string? _backendUnavailableMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _dashboard = await ApiClient.GetTelemetryDashboardAsync(30);
        }
        catch (ControlPlaneApiException exception)
        {
            _denial = exception.AuthorizationDenied;
            _error = $"{T["TelemetryDashboardTitle"]}: {exception.Message}";
        }
        catch (ControlPlaneApiUnavailableException exception)
        {
            _denial = null;
            _error = null;
            _backendUnavailableMessage = exception.Message;
        }
        catch (Exception exception)
        {
            _denial = null;
            _error = $"{T["TelemetryDashboardTitle"]}: {exception.Message}";
        }
    }

    private static string FormatTime(DateTimeOffset? value)
        => value?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "—";
}
