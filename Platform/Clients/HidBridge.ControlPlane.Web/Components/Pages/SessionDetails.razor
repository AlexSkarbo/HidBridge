    [JSInvokable]
    public async Task OnLiveInputBatch(IReadOnlyList<LiveInputEvent>? events)
    {
        if (!_liveControlEnabled || !_isLiveControlAvailable || events is null || events.Count == 0)
        {
            if (_liveControlEnabled && !_isLiveControlAvailable)
            {
                _ = await SetLiveControlEnabledAsync(false, updateMessage: false, autoEnabled: false);
                _actionMessage = GetLiveControlBlockedHint();
                await InvokeAsync(StateHasChanged);
            }
            return;
        }

        var batchItems = new List<SessionCommandBatchItemViewModel>(events.Count);
        foreach (var evt in events)
        {
            if (string.IsNullOrWhiteSpace(evt.Action))
            {
                continue;
            }

            var args = new List<KeyValuePair<string, object?>>();
            if (evt.Args is not null)
            {
                foreach (var pair in evt.Args)
                {
                    args.Add(new KeyValuePair<string, object?>(pair.Key, pair.Value));
                }
            }

            batchItems.Add(BuildBatchItem(evt.Action, args));
        }

        if (batchItems.Count == 0)
        {
            return;
        }

        await DispatchBatchInternalAsync("Live Control", batchItems);
    }

