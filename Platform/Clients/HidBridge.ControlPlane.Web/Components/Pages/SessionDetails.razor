        }

        return new SessionCommandBatchItemViewModel
        {
            CommandId = $"cmd-{Guid.NewGuid():N}",
            Channel = "Hid",
            Action = action,
            Args = commandArgs,
            TimeoutMs = 3000,
            IdempotencyKey = $"idem-{Guid.NewGuid():N}",
        };
    }

    private async Task DispatchBatchInternalAsync(
        string scenarioName,
        IReadOnlyList<SessionCommandBatchItemViewModel> items)
    {
        if (items.Count == 0)
        {
            return;
        }

        try
        {
            _busy = true;
            _actionMessage = null;
            _error = null;
            _denial = null;
            _backendUnavailableMessage = null;

            var body = new SessionCommandBatchDispatchRequestViewModel
            {
                Commands = items,
                TenantId = Identity.TenantId,
                OrganizationId = Identity.OrganizationId,
                OperatorRoles = Identity.OperatorRoles,
            };

            var ack = await ApiClient.DispatchCommandBatchAsync(SessionId, body);
            var rejectedOrTimeout = ack?.Results.FirstOrDefault(result =>
                !IsAcceptedCommandAck(result.Status));
            if (rejectedOrTimeout is not null)
            {
                _actionMessage = $"{scenarioName}: {rejectedOrTimeout.Status}";
                var detail = rejectedOrTimeout.Error is null
                    ? rejectedOrTimeout.Status
                    : $"{rejectedOrTimeout.Error.Code}: {rejectedOrTimeout.Error.Message}";
                RegisterCommandScenarioResult("live-batch", scenarioName, rejectedOrTimeout.Status, false, detail);
            }
            else
            {
                _actionMessage = $"{scenarioName}: Applied ({ack?.AppliedCount ?? 0}).";
                RegisterCommandScenarioResult("live-batch", scenarioName, "Applied", true, $"applied={ack?.AppliedCount ?? 0}");
            }

            await RefreshAsync();
        }
        catch (ControlPlaneApiUnavailableException exception)
        {
            _denial = null;
            _error = null;
            _backendUnavailableMessage = exception.Message;
            RegisterCommandScenarioResult("live-batch", scenarioName, "Unavailable", false, exception.Message);
        }
        catch (ControlPlaneApiException exception)
        {
            _denial = exception.AuthorizationDenied;
            _error = ResolveApiErrorMessage(exception);
            _backendUnavailableMessage = null;
            RegisterCommandScenarioResult("live-batch", scenarioName, "Rejected", false, ResolveApiErrorMessage(exception));
        }
        catch (Exception exception)
        {
            _denial = null;
            _error = exception.Message;
            _backendUnavailableMessage = null;
            RegisterCommandScenarioResult("live-batch", scenarioName, "Rejected", false, exception.Message);
        }
        finally
        {
            _busy = false;
        }
    }

    private static string NormalizeMouseButton(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "left";
        }

        var normalized = value.Trim().ToLowerInvariant();
        return normalized is "left" or "right" or "middle"
            ? normalized
            : "left";
    }

    private static byte ClampByte(int value)
        => (byte)Math.Clamp(value, byte.MinValue, byte.MaxValue);

