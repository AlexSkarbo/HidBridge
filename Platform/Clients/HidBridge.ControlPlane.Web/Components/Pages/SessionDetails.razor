        => entry.Accepted ? T["ScenarioPass"] : T["ScenarioReject"];

    private static string GetTrailBadgeClass(CommandAuditTrailEntry entry)
        => entry.Accepted ? "hid-badge hid-badge--positive" : "hid-badge hid-badge--danger";

    private void RegisterCommandScenarioResult(
        string scenarioId,
        string scenarioName,
        string ackStatus,
        bool accepted,
        string detail)
    {
        var occurredAtUtc = DateTimeOffset.UtcNow;
        _commandScenarioSnapshots[scenarioId] = new CommandScenarioSnapshot(ackStatus, accepted, detail, occurredAtUtc);

        _commandAuditTrail.Insert(0, new CommandAuditTrailEntry(scenarioName, ackStatus, accepted, detail, occurredAtUtc));
        if (_commandAuditTrail.Count > CommandAuditTrailCapacity)
        {
            _commandAuditTrail.RemoveRange(CommandAuditTrailCapacity, _commandAuditTrail.Count - CommandAuditTrailCapacity);
        }
    }

    private static bool IsAcceptedCommandAck(string? status)
        => string.Equals(status, "Accepted", StringComparison.OrdinalIgnoreCase)
           || string.Equals(status, "Applied", StringComparison.OrdinalIgnoreCase);

    private async Task SyncLiveControlStateAfterRefreshAsync()
    {
        if (_liveControlEnabled && !_isLiveControlAvailable)
        {
            _ = await SetLiveControlEnabledAsync(false, updateMessage: false, autoEnabled: false);
            _actionMessage ??= GetLiveControlBlockedHint();
        }

        if (_liveControlAutoArmRequested && _isLiveControlAvailable)
        {
            var enabled = await SetLiveControlEnabledAsync(
                true,
                updateMessage: _liveInputModule is not null,
                autoEnabled: true);
            if (enabled)
            {
                _liveControlAutoArmRequested = false;
            }
        }
        else if (!IsSessionActiveForControl())
        {
            _liveControlAutoArmRequested = false;
        }
    }

    private async Task<bool> SetLiveControlEnabledAsync(bool enabled, bool updateMessage, bool autoEnabled)
    {
        if (_liveInputModule is null && enabled)
        {
            _liveControlEnabled = false;
            _pointerLockEnabled = false;
            if (updateMessage)
            {
                _actionMessage = T["LiveControlJsUnavailableMessage"];
            }

            return false;
        }

        if (_liveInputModule is not null)
        {
            await _liveInputModule.InvokeVoidAsync("setLiveControlEnabled", enabled);
            if (enabled)
            {
                try
                {
                    _ = await _liveInputModule.InvokeAsync<bool>("focusCaptureZone");
                }
                catch
                {
                    // Focus helper is best-effort only.
                }
            }
            else
            {
                await _liveInputModule.InvokeVoidAsync("exitPointerLock");
            }
        }

        _liveControlEnabled = enabled;
        if (!enabled)
        {
            _pointerLockEnabled = false;
        }

        if (!updateMessage)
        {
            return _liveControlEnabled;
        }

        if (enabled)
        {
            _actionMessage = autoEnabled
                ? T["LiveControlAutoEnabledMessage"]
                : T["LiveControlEnabledMessage"];
        }
        else
        {
            _actionMessage = T["LiveControlDisabledMessage"];
        }

        return _liveControlEnabled;
    }

