    /// <summary>
    /// Returns safe absolute playback href suitable for target=_blank links.
    /// </summary>
    private static string? TryGetTransportMediaPlaybackHref(
        SessionTransportReadinessViewModel? readiness,
        SessionTransportHealthViewModel? health)
    {
        var playback = GetTransportMediaPlayback(readiness, health);
        if (string.IsNullOrWhiteSpace(playback) || string.Equals(playback, "—", StringComparison.Ordinal))
        {
            return null;
        }

        if (!Uri.TryCreate(playback, UriKind.Absolute, out var uri))
        {
            return null;
        }

        return string.Equals(uri.Scheme, Uri.UriSchemeHttp, StringComparison.OrdinalIgnoreCase)
            || string.Equals(uri.Scheme, Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase)
            ? uri.ToString()
            : null;
    }

