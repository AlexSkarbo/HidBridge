@page "/sessions/{SessionId}"
@attribute [Authorize(Policy = OperatorPolicies.Viewer)]
@implements IAsyncDisposable
@using System.Text.Json
@using System.Globalization
@using Microsoft.JSInterop
@inject HidBridge.ControlPlane.Web.Services.ControlPlaneApiClient ApiClient
@inject OperatorIdentityContext Identity
@inject OperatorText T
@inject NavigationManager Navigation
@inject IJSRuntime Js

<PageTitle>@T["SessionRoomTitle"]</PageTitle>

<section class="hid-page">
    <div class="hid-page-heading">
        <p class="hid-section-kicker">@T["SessionRoomTitle"]</p>
        <h2 class="hid-section-title">@SessionId</h2>
        @if (_dashboard is not null)
        {
            <p class="hid-section-subtitle">@_dashboard.AgentId · @_dashboard.EndpointId · @_dashboard.State</p>
        }
    </div>

    @if (_denial is not null)
    {
        <AuthorizationDeniedPanel Denial="_denial" Title="@T["AccessDenied"]" />
    }
    else if (_backendUnavailableMessage is not null)
    {
        <BackendUnavailablePanel Message="@_backendUnavailableMessage" Title="@T["BackendUnavailable"]" Hint="@T["BackendUnavailableHint"]" />
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="hid-alert hid-alert--danger">@_error</div>
    }

    @if (!string.IsNullOrWhiteSpace(_actionMessage))
    {
        <div class="hid-alert hid-alert--info">@_actionMessage</div>
    }

    @if (_dashboard is not null && string.Equals(_dashboard.State, "Recovering", StringComparison.OrdinalIgnoreCase))
    {
        <div class="hid-alert hid-alert--info">@T["SessionRecoveringHint"]</div>
    }

    @if (_dashboard is not null && string.Equals(_dashboard.State, "Failed", StringComparison.OrdinalIgnoreCase))
    {
        <div class="hid-alert hid-alert--warning">@GetSessionFailedHint()</div>
    }

    @if (_backendUnavailableMessage is not null || !string.IsNullOrWhiteSpace(_error) || _denial is not null)
    {
    }
    else if (_dashboard is null || _control is null || _lobby is null || _participants is null || _timeline is null)
    {
        <div class="hid-card-soft hid-empty-state">@T["LoadingSessionDetails"]</div>
    }
    else
    {
        var participants = _participants!;
        var timeline = _timeline!;

        <div class="hid-card-soft">
            <div class="hid-panel-toolbar">
                <div>
                    <h3 class="hid-card-title">@T["RoomFlowTitle"]</h3>
                    <p class="hid-card-subtitle">@T["RoomFlowSubtitle"]</p>
                </div>
                <div class="hid-candidate-actions">
                    <a class="hid-button-secondary hid-button-sm" href="/">@T["BackToFleet"]</a>
                    <button class="hid-button-danger hid-button-sm" disabled="@_busy" @onclick="EndSessionAsync">@T["EndRoom"]</button>
                    <button class="hid-button-secondary hid-button-sm" @onclick="RefreshAsync">@T["Refresh"]</button>
                </div>
            </div>
            <div class="hid-inline-meta">
                <span>@T["RequestedInvitations"]: @_lobby.Requested.Count</span>
                <span>@T["PendingInvitations"]: @_lobby.Pending.Count</span>
                <span>@T["AcceptedInvitations"]: @_lobby.Accepted.Count</span>
                <span>@T["CurrentController"]: @(_dashboard.ActiveControllerPrincipalId ?? "—")</span>
            </div>
            <div class="hid-subtle-copy">@string.Format(T["RoomFlowHint"], SessionId)</div>
            <div class="hid-meta-grid">
                <div class="hid-detail-card">
                    <div class="hid-detail-label">@T["RoomReadyTitle"]</div>
                    <div class="hid-detail-value">@NextRecommendedAction</div>
                    <div class="hid-meta-note">@T["RoomReadyHint"]</div>
                </div>
                <div class="hid-detail-card">
                    <div class="hid-detail-label">@T["RoomShareLink"]</div>
                    <input class="hid-input" readonly value="@SessionRoomUrl" />
                    <div class="hid-meta-note">@T["RoomShareHint"]</div>
                </div>
                <div class="hid-detail-card">
                    <div class="hid-detail-label">@T["DemoChecklist"]</div>
                    <div class="hid-inline-meta">
                        <span>1. @T["DemoChecklistStep1"]</span>
                        <span>2. @T["DemoChecklistStep2"]</span>
                        <span>3. @T["DemoChecklistStep3"]</span>
                        <span>4. @T["DemoChecklistStep4"]</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="hid-stat-grid">
            <div class="hid-stat-card">
                <div class="hid-stat-label">@T["State"]</div>
                <div class="hid-stat-value">@_dashboard.State</div>
            </div>
            <div class="hid-stat-card">
                <div class="hid-stat-label">@T["Participants"]</div>
                <div class="hid-stat-value">@_dashboard.ParticipantCount</div>
            </div>
            <div class="hid-stat-card">
                <div class="hid-stat-label">@T["FailedCommands"]</div>
                <div class="hid-stat-value hid-accent-warning">@_dashboard.FailedCommandCount</div>
            </div>
            <div class="hid-stat-card">
                <div class="hid-stat-label">@T["Controller"]</div>
                <div class="hid-stat-value">@(_dashboard.ActiveControllerPrincipalId ?? "—")</div>
            </div>
        </div>

        <div class="hid-page-grid hid-page-grid--session">
            <section class="hid-section-block">
                <div>
                    <h3 class="hid-card-title">@T["SessionSnapshot"]</h3>
                    <div class="hid-meta-grid">
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["Agent"]</div><div class="hid-detail-value">@_dashboard.AgentId</div></div>
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["Endpoint"]</div><div class="hid-detail-value">@_dashboard.EndpointId</div></div>
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["Profile"]</div><div class="hid-detail-value">@_dashboard.Profile</div></div>
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["OwnerRole"]</div><div class="hid-detail-value">@_dashboard.OwnerRole</div></div>
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["RequestedBy"]</div><div class="hid-detail-value">@_dashboard.RequestedBy</div></div>
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["RoomId"]</div><div class="hid-detail-value">@SessionId</div></div>
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["LeaseExpires"]</div><div class="hid-detail-value">@FormatTime(_dashboard.LeaseExpiresAtUtc)</div></div>
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["StateReason"]</div><div class="hid-detail-value">@GetStateReasonLabel()</div></div>
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["StateChangedAt"]</div><div class="hid-detail-value">@FormatTime(_dashboard.StateChangedAtUtc)</div></div>
                    </div>
                </div>

                <div>
                    <h3 class="hid-card-title">@T["IdentityAccessPanel"]</h3>
                    <div class="hid-meta-grid">
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["CurrentOperator"]</div><div class="hid-detail-value">@Identity.DisplayName</div><div class="hid-meta-note">@CurrentOperatorPrincipalId</div></div>
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["Tenant"]</div><div class="hid-detail-value">@Identity.TenantId</div><div class="hid-meta-note">@T["Organization"]: @Identity.OrganizationId</div></div>
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["Roles"]</div><div class="hid-detail-value">@Identity.RoleSummary</div></div>
                    </div>
                    <div class="hid-subtle-copy">@ModerationAccessMessage</div>
                </div>

                <div>
                    <div class="hid-panel-toolbar">
                        <div>
                            <h3 class="hid-card-title">@T["TransportHealthPanel"]</h3>
                            <p class="hid-card-subtitle">@T["TransportHealthSubtitle"]</p>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_transportHealthError))
                    {
                        <div class="hid-alert hid-alert--warning">@_transportHealthError</div>
                    }
                    else if (_transportReadiness is null && _transportHealth is null)
                    {
                        <div class="hid-empty-state">@T["LoadingTransportHealth"]</div>
                    }
                    else
                    {
                        <div class="hid-meta-grid">
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportProviderLabel"]</div><div class="hid-detail-value">@(_transportReadiness?.Provider ?? _transportHealth?.Provider ?? "—")</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportRouteSource"]</div><div class="hid-detail-value">@(_transportReadiness?.ProviderSource ?? _transportHealth?.ProviderSource ?? "—")</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportReadiness"]</div><div class="hid-detail-value">@GetTransportReadinessLabel()</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportReadinessReasonCode"]</div><div class="hid-detail-value">@GetTransportReadinessReasonCode()</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportReadinessReason"]</div><div class="hid-detail-value">@GetTransportReadinessReason()</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["ReportedAt"]</div><div class="hid-detail-value">@FormatTime(_transportReadiness?.EvaluatedAtUtc ?? _transportHealth?.ReportedAtUtc)</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportOnlinePeers"]</div><div class="hid-detail-value">@GetTransportOnlinePeerCount(_transportReadiness, _transportHealth)</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportPendingAcks"]</div><div class="hid-detail-value">@GetTransportMetricValue(_transportHealth, "pendingAckCount")</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportPeerState"]</div><div class="hid-detail-value">@GetTransportPeerState(_transportReadiness, _transportHealth)</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportPeerLastSeen"]</div><div class="hid-detail-value">@GetTransportPeerLastSeen(_transportReadiness, _transportHealth)</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportLastRelayAckAt"]</div><div class="hid-detail-value">@GetTransportLastRelayAckAt(_transportReadiness, _transportHealth)</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportMediaReady"]</div><div class="hid-detail-value">@GetTransportMediaReady(_transportReadiness, _transportHealth)</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportMediaState"]</div><div class="hid-detail-value">@GetTransportMediaState(_transportReadiness, _transportHealth)</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportMediaSource"]</div><div class="hid-detail-value">@GetTransportMediaSource(_transportReadiness, _transportHealth)</div></div>
                            <div class="hid-detail-card">
                                <div class="hid-detail-label">@T["TransportMediaPlayback"]</div>
                                @if (TryGetTransportMediaPlaybackHref(_transportReadiness, _transportHealth) is { } playbackHref)
                                {
                                    <div class="hid-detail-value">
                                        <a href="@playbackHref" target="_blank" rel="noopener noreferrer">@playbackHref</a>
                                    </div>
                                }
                                else
                                {
                                    <div class="hid-detail-value">@GetTransportMediaPlayback(_transportReadiness, _transportHealth)</div>
                                }
                            </div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportMediaKind"]</div><div class="hid-detail-value">@GetTransportMediaKind(_transportReadiness, _transportHealth)</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportMediaStreamId"]</div><div class="hid-detail-value">@GetTransportMediaStreamId(_transportReadiness, _transportHealth)</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportMediaReportedAt"]</div><div class="hid-detail-value">@GetTransportMediaReportedAt(_transportReadiness, _transportHealth)</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportMediaVideo"]</div><div class="hid-detail-value">@GetTransportMediaVideo(_transportReadiness, _transportHealth)</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportMediaAudio"]</div><div class="hid-detail-value">@GetTransportMediaAudio(_transportReadiness, _transportHealth)</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportMediaBackendAutoStart"]</div><div class="hid-detail-value">@GetTransportBackendAutoStart(_transportHealth)</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportMediaBackendRunning"]</div><div class="hid-detail-value">@GetTransportBackendRunning(_transportHealth)</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportMediaBackendState"]</div><div class="hid-detail-value">@GetTransportBackendState(_transportHealth)</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportMediaBackendPid"]</div><div class="hid-detail-value">@GetTransportMetricValue(_transportHealth, "lastPeerMediaBackendPid")</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportMediaBackendUptime"]</div><div class="hid-detail-value">@GetTransportBackendUptime(_transportHealth)</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportMediaBackendReportedAt"]</div><div class="hid-detail-value">@GetTransportBackendReportedAt(_transportHealth)</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportRoundtripMs"]</div><div class="hid-detail-value">@GetAckRoundtripMs(_transportHealth?.LastCommandAck)</div></div>
                        </div>

                        @if (!string.Equals(GetTransportPeerFailureReason(_transportReadiness, _transportHealth), "—", StringComparison.Ordinal))
                        {
                            <div class="hid-meta-note">@T["TransportPeerFailureReason"]: @GetTransportPeerFailureReason(_transportReadiness, _transportHealth)</div>
                        }

                        @if (!string.Equals(GetTransportMediaFailureReason(_transportReadiness, _transportHealth), "—", StringComparison.Ordinal))
                        {
                            <div class="hid-meta-note">@T["TransportMediaFailureReason"]: @GetTransportMediaFailureReason(_transportReadiness, _transportHealth)</div>
                        }

                        @if (!string.Equals(GetTransportMetricValue(_transportHealth, "lastPeerMediaBackendLastLine"), "—", StringComparison.Ordinal))
                        {
                            <div class="hid-meta-note">@T["TransportMediaBackendLastLine"]: @GetTransportMetricValue(_transportHealth, "lastPeerMediaBackendLastLine")</div>
                        }

                        @if (_transportHealth?.LastPeerConsecutiveFailures.HasValue == true || _transportHealth?.LastPeerReconnectBackoffMs.HasValue == true)
                        {
                            <div class="hid-meta-note">@T["TransportPeerStability"]: @GetTransportPeerStability(_transportHealth)</div>
                        }

                        @if (_transportHealth?.LastCommandAck is not { } lastAck)
                        {
                            <div class="hid-empty-state">@T["NoTransportAckYet"]</div>
                        }
                        else
                        {
                            <div class="hid-detail-card">
                                <div class="hid-detail-label">@T["LastTransportAck"]</div>
                                <div class="hid-detail-value">@lastAck.Action -> @lastAck.Status</div>
                                <div class="hid-inline-meta">
                                    <span>@T["CommandId"]: @lastAck.CommandId</span>
                                    <span>@T["Channel"]: @lastAck.Channel</span>
                                    <span>@T["LastCommand"]: @FormatTime(lastAck.CompletedAtUtc ?? lastAck.CreatedAtUtc)</span>
                                    <span>@T["LastAckRoute"]: @GetAckRoute(lastAck)</span>
                                </div>
                                @if (lastAck.Error is not null)
                                {
                                    <div class="hid-meta-note">@lastAck.Error.Code · @lastAck.Error.Message</div>
                                    @if (lastAck.Error.Details is not null && lastAck.Error.Details.Count > 0)
                                    {
                                        <div class="hid-meta-note">@T["ErrorDetails"]: @FormatErrorDetails(lastAck.Error.Details)</div>
                                    }
                                }
                            </div>
                        }

                        <div>
                            <h4 class="hid-card-title">@T["WebRtcSignalInbox"]</h4>
                            @if (_webRtcSignals.Count == 0)
                            {
                                <div class="hid-empty-state">@T["NoWebRtcSignals"]</div>
                            }
                            else
                            {
                                <div class="hid-list-stack">
                                    @foreach (var signal in _webRtcSignals.Take(5))
                                    {
                                        <div class="hid-list-card">
                                            <div class="hid-list-card-header">
                                                <div>
                                                    <div class="hid-list-title">#@signal.Sequence · @signal.Kind</div>
                                                    <div class="hid-list-subtitle">@signal.SenderPeerId -> @(signal.RecipientPeerId ?? "*")</div>
                                                </div>
                                                <div class="hid-list-timestamp">@FormatTime(signal.CreatedAtUtc)</div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

                <div id="live-input-capture-zone" tabindex="0">
                    @{
                        var controlBlocked = GetControlBlockedDiagnostic();
                    }
                    <SessionMediaPanel SessionId="@SessionId"
                                       PlaybackUrl="@GetTransportMediaPlayback(_transportReadiness, _transportHealth)"
                                       MediaReady="@(_transportReadiness?.MediaReady ?? _transportHealth?.MediaReady)"
                                       MediaState="@GetTransportMediaState(_transportReadiness, _transportHealth)"
                                       MediaStreamId="@GetTransportMediaStreamId(_transportReadiness, _transportHealth)"
                                       BackendReady="@(_transportReadiness?.Ready)"
                                       BackendReasonCode="@_transportReadiness?.ReasonCode"
                                       BackendReason="@_transportReadiness?.Reason"
                                       BackendMediaFailureReason="@GetTransportMediaFailureReason(_transportReadiness, _transportHealth)"
                                       ControlBlockedCode="@controlBlocked?.Code"
                                       ControlBlockedReason="@controlBlocked?.Message"
                                       LiveControlAvailable="@_isLiveControlAvailable"
                                       LiveControlEnabled="@_liveControlEnabled" />
                </div>

                <div>
                    <div class="hid-panel-toolbar">
                        <div>
                            <h3 class="hid-card-title">@T["ControlOperationsPanel"]</h3>
                            <p class="hid-card-subtitle">@T["ControlArbitration"]</p>
                            <p class="hid-meta-note">@T["OperatorPrincipal"]: @CurrentOperatorPrincipalId</p>
                        </div>
                        <button class="hid-button-secondary" @onclick="RefreshAsync">@T["Refresh"]</button>
                    </div>

                    @if (GetControlBlockedDiagnostic() is { } controlBlockedBanner)
                    {
                        <div class="hid-alert hid-alert--warning">@string.Format(T["ControlBlockedBannerWithCode"], controlBlockedBanner.Code, controlBlockedBanner.Message)</div>
                    }

                    @if (_control.ActiveLease is null)
                    {
                        <div class="hid-empty-state">@T["NoActiveControlLease"]</div>
                    }
                    else
                    {
                        <div class="hid-lease-card">
                            <div class="hid-detail-label">@T["CurrentLease"]</div>
                            <div class="hid-detail-value">@_control.ActiveLease.PrincipalId</div>
                            <div class="hid-meta-note">@T["Participant"]: @_control.ActiveLease.ParticipantId</div>
                            <div class="hid-meta-note">@T["GrantedBy"]: @_control.ActiveLease.GrantedBy</div>
                            <div class="hid-meta-note">@T["LeaseExpires"]: @FormatTime(_control.ActiveLease.ExpiresAtUtc)</div>
                            <div class="hid-meta-note">@T["LeaseRemaining"]: @FormatLeaseRemaining(_control.ActiveLease.ExpiresAtUtc)</div>
                        </div>
                    }

                    <div class="hid-subtle-copy">@T["ControlRequestHelp"]</div>

                    <div class="hid-candidate-stack">
                        @foreach (var candidate in _control.Candidates)
                        {
                            <div class="hid-candidate-card">
                                <div class="hid-candidate-card-header">
                                    <div>
                                        <div class="hid-candidate-title">@candidate.PrincipalId</div>
                                        <div class="hid-list-subtitle">@candidate.ParticipantId · @candidate.Role</div>
                                    </div>
                                    <div class="hid-candidate-actions">
                                        <button class="hid-button-secondary hid-button-sm"
                                                disabled="@(!candidate.IsEligible || _busy)"
                                                @onclick="() => RequestControlAsync(candidate)">
                                            @T["RequestControl"]
                                        </button>
                                        <button class="hid-button-secondary hid-button-sm"
                                                disabled="@(_busy || !candidate.IsCurrentController || !CanRelease(candidate))"
                                                @onclick="() => ReleaseControlAsync(candidate)">
                                            @T["Release"]
                                        </button>
                                        <button class="hid-button-danger hid-button-sm"
                                                disabled="@(_busy || !_canModerate)"
                                                @onclick="() => ForceTakeoverAsync(candidate)">
                                            @T["ForceTakeover"]
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div>
                    <div class="hid-panel-toolbar">
                        <div>
                            <h3 class="hid-card-title">@T["CommandDeckTitle"]</h3>
                            <p class="hid-card-subtitle">@T["CommandDeckSubtitle"]</p>
                        </div>
                    </div>

                    <p class="hid-meta-note">@T["CommandDeckHint"]</p>
                    <p class="hid-meta-note"><strong>@T["ControlPathStatusLabel"]</strong> @GetLiveControlPathStatus()</p>
                    <div class="hid-candidate-actions" style="margin-bottom: 0.75rem;">
                        <button class="hid-button-primary hid-button-sm"
                                disabled="@(_busy || !_isLiveControlAvailable)"
                                @onclick="ToggleLiveControlAsync">
                            @(_liveControlEnabled ? "Live Control: ON" : "Live Control: OFF")
                        </button>
                        <button class="hid-button-secondary hid-button-sm"
                                disabled="@(_busy || !_liveControlEnabled)"
                                @onclick="TogglePointerLockAsync">
                            @(_pointerLockEnabled ? "Pointer Lock: ON" : "Pointer Lock: OFF")
                        </button>
                        <button class="hid-button-danger hid-button-sm"
                                disabled="@(_busy || !_isLiveControlAvailable)"
                                @onclick="PanicResetAsync">
                            Panic Reset
                        </button>
                    </div>
                    @if (!_isLiveControlAvailable)
                    {
                        <p class="hid-meta-note">@GetLiveControlBlockedHint()</p>
                        <div class="hid-candidate-actions" style="margin-bottom: 0.75rem;">
                            <button class="hid-button-secondary hid-button-sm"
                                    disabled="@(!CanQuickRequestControl())"
                                    @onclick="RequestControlForCurrentOperatorAsync">
                                @T["RequestControl"]
                            </button>
                            <button class="hid-button-danger hid-button-sm"
                                    disabled="@(!CanQuickForceTakeover())"
                                    @onclick="ForceTakeoverForCurrentOperatorAsync">
                                @T["ForceTakeover"]
                            </button>
                        </div>
                    }

                    <div class="hid-form-grid">
                        <label class="hid-field">
                            <span class="hid-field-label">@T["CommandTextLabel"]</span>
                            <input class="hid-input" @bind="_demoCommandText" />
                        </label>
                        <label class="hid-field">
                            <span class="hid-field-label">@T["CommandShortcutLabel"]</span>
                            <input class="hid-input" @bind="_demoShortcut" />
                        </label>
                        <label class="hid-field">
                            <span class="hid-field-label">@T["CommandMouseDxLabel"]</span>
                            <input class="hid-input" type="number" @bind="_demoMouseDx" />
                        </label>
                        <label class="hid-field">
                            <span class="hid-field-label">@T["CommandMouseDyLabel"]</span>
                            <input class="hid-input" type="number" @bind="_demoMouseDy" />
                        </label>
                        <label class="hid-field">
                            <span class="hid-field-label">@T["CommandMouseWheelLabel"]</span>
                            <input class="hid-input" type="number" @bind="_demoMouseWheelDelta" />
                        </label>
                        <label class="hid-field">
                            <span class="hid-field-label">@T["CommandMouseButtonLabel"]</span>
                            <input class="hid-input" @bind="_demoMouseButton" />
                        </label>
                        <label class="hid-field">
                            <span class="hid-field-label">@T["CommandKeyboardUsageLabel"]</span>
