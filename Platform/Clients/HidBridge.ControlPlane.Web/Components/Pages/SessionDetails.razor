@page "/sessions/{SessionId}"
@attribute [Authorize(Policy = OperatorPolicies.Viewer)]
@implements IAsyncDisposable
@using System.Text.Json
@using System.Globalization
@inject HidBridge.ControlPlane.Web.Services.ControlPlaneApiClient ApiClient
@inject OperatorIdentityContext Identity
@inject OperatorText T
@inject NavigationManager Navigation

<PageTitle>@T["SessionRoomTitle"]</PageTitle>

<section class="hid-page">
    <div class="hid-page-heading">
        <p class="hid-section-kicker">@T["SessionRoomTitle"]</p>
        <h2 class="hid-section-title">@SessionId</h2>
        @if (_dashboard is not null)
        {
            <p class="hid-section-subtitle">@_dashboard.AgentId · @_dashboard.EndpointId · @_dashboard.State</p>
        }
    </div>

    @if (_denial is not null)
    {
        <AuthorizationDeniedPanel Denial="_denial" Title="@T["AccessDenied"]" />
    }
    else if (_backendUnavailableMessage is not null)
    {
        <BackendUnavailablePanel Message="@_backendUnavailableMessage" Title="@T["BackendUnavailable"]" Hint="@T["BackendUnavailableHint"]" />
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="hid-alert hid-alert--danger">@_error</div>
    }

    @if (!string.IsNullOrWhiteSpace(_actionMessage))
    {
        <div class="hid-alert hid-alert--info">@_actionMessage</div>
    }

    @if (_dashboard is not null && string.Equals(_dashboard.State, "Recovering", StringComparison.OrdinalIgnoreCase))
    {
        <div class="hid-alert hid-alert--info">@T["SessionRecoveringHint"]</div>
    }

    @if (_dashboard is not null && string.Equals(_dashboard.State, "Failed", StringComparison.OrdinalIgnoreCase))
    {
        <div class="hid-alert hid-alert--warning">@GetSessionFailedHint()</div>
    }

    @if (_backendUnavailableMessage is not null || !string.IsNullOrWhiteSpace(_error) || _denial is not null)
    {
    }
    else if (_dashboard is null || _control is null || _lobby is null || _participants is null || _timeline is null)
    {
        <div class="hid-card-soft hid-empty-state">@T["LoadingSessionDetails"]</div>
    }
    else
    {
        var participants = _participants!;
        var timeline = _timeline!;

        <div class="hid-card-soft">
            <div class="hid-panel-toolbar">
                <div>
                    <h3 class="hid-card-title">@T["RoomFlowTitle"]</h3>
                    <p class="hid-card-subtitle">@T["RoomFlowSubtitle"]</p>
                </div>
                <div class="hid-candidate-actions">
                    <a class="hid-button-secondary hid-button-sm" href="/">@T["BackToFleet"]</a>
                    <button class="hid-button-danger hid-button-sm" disabled="@_busy" @onclick="EndSessionAsync">@T["EndRoom"]</button>
                    <button class="hid-button-secondary hid-button-sm" @onclick="RefreshAsync">@T["Refresh"]</button>
                </div>
            </div>
            <div class="hid-inline-meta">
                <span>@T["RequestedInvitations"]: @_lobby.Requested.Count</span>
                <span>@T["PendingInvitations"]: @_lobby.Pending.Count</span>
                <span>@T["AcceptedInvitations"]: @_lobby.Accepted.Count</span>
                <span>@T["CurrentController"]: @(_dashboard.ActiveControllerPrincipalId ?? "—")</span>
            </div>
            <div class="hid-subtle-copy">@string.Format(T["RoomFlowHint"], SessionId)</div>
            <div class="hid-meta-grid">
                <div class="hid-detail-card">
                    <div class="hid-detail-label">@T["RoomReadyTitle"]</div>
                    <div class="hid-detail-value">@NextRecommendedAction</div>
                    <div class="hid-meta-note">@T["RoomReadyHint"]</div>
                </div>
                <div class="hid-detail-card">
                    <div class="hid-detail-label">@T["RoomShareLink"]</div>
                    <input class="hid-input" readonly value="@SessionRoomUrl" />
                    <div class="hid-meta-note">@T["RoomShareHint"]</div>
                </div>
                <div class="hid-detail-card">
                    <div class="hid-detail-label">@T["DemoChecklist"]</div>
                    <div class="hid-inline-meta">
                        <span>1. @T["DemoChecklistStep1"]</span>
                        <span>2. @T["DemoChecklistStep2"]</span>
                        <span>3. @T["DemoChecklistStep3"]</span>
                        <span>4. @T["DemoChecklistStep4"]</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="hid-stat-grid">
            <div class="hid-stat-card">
                <div class="hid-stat-label">@T["State"]</div>
                <div class="hid-stat-value">@_dashboard.State</div>
            </div>
            <div class="hid-stat-card">
                <div class="hid-stat-label">@T["Participants"]</div>
                <div class="hid-stat-value">@_dashboard.ParticipantCount</div>
            </div>
            <div class="hid-stat-card">
                <div class="hid-stat-label">@T["FailedCommands"]</div>
                <div class="hid-stat-value hid-accent-warning">@_dashboard.FailedCommandCount</div>
            </div>
            <div class="hid-stat-card">
                <div class="hid-stat-label">@T["Controller"]</div>
                <div class="hid-stat-value">@(_dashboard.ActiveControllerPrincipalId ?? "—")</div>
            </div>
        </div>

        <div class="hid-page-grid hid-page-grid--session">
            <section class="hid-section-block">
                <div>
                    <h3 class="hid-card-title">@T["SessionSnapshot"]</h3>
                    <div class="hid-meta-grid">
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["Agent"]</div><div class="hid-detail-value">@_dashboard.AgentId</div></div>
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["Endpoint"]</div><div class="hid-detail-value">@_dashboard.EndpointId</div></div>
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["Profile"]</div><div class="hid-detail-value">@_dashboard.Profile</div></div>
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["OwnerRole"]</div><div class="hid-detail-value">@_dashboard.OwnerRole</div></div>
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["RequestedBy"]</div><div class="hid-detail-value">@_dashboard.RequestedBy</div></div>
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["RoomId"]</div><div class="hid-detail-value">@SessionId</div></div>
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["LeaseExpires"]</div><div class="hid-detail-value">@FormatTime(_dashboard.LeaseExpiresAtUtc)</div></div>
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["StateReason"]</div><div class="hid-detail-value">@GetStateReasonLabel()</div></div>
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["StateChangedAt"]</div><div class="hid-detail-value">@FormatTime(_dashboard.StateChangedAtUtc)</div></div>
                    </div>
                </div>

                <div>
                    <h3 class="hid-card-title">@T["IdentityAccessPanel"]</h3>
                    <div class="hid-meta-grid">
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["CurrentOperator"]</div><div class="hid-detail-value">@Identity.DisplayName</div><div class="hid-meta-note">@CurrentOperatorPrincipalId</div></div>
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["Tenant"]</div><div class="hid-detail-value">@Identity.TenantId</div><div class="hid-meta-note">@T["Organization"]: @Identity.OrganizationId</div></div>
                        <div class="hid-detail-card"><div class="hid-detail-label">@T["Roles"]</div><div class="hid-detail-value">@Identity.RoleSummary</div></div>
                    </div>
                    <div class="hid-subtle-copy">@ModerationAccessMessage</div>
                </div>

                <div>
                    <div class="hid-panel-toolbar">
                        <div>
                            <h3 class="hid-card-title">@T["TransportHealthPanel"]</h3>
                            <p class="hid-card-subtitle">@T["TransportHealthSubtitle"]</p>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_transportHealthError))
                    {
                        <div class="hid-alert hid-alert--warning">@_transportHealthError</div>
                    }
                    else if (_transportHealth is null)
                    {
                        <div class="hid-empty-state">@T["LoadingTransportHealth"]</div>
                    }
                    else
                    {
                        <div class="hid-meta-grid">
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportProviderLabel"]</div><div class="hid-detail-value">@_transportHealth.Provider</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportRouteSource"]</div><div class="hid-detail-value">@_transportHealth.ProviderSource</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportConnectivity"]</div><div class="hid-detail-value">@(_transportHealth.Connected ? T["Yes"] : T["No"])</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportStatus"]</div><div class="hid-detail-value">@_transportHealth.Status</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["ReportedAt"]</div><div class="hid-detail-value">@FormatTime(_transportHealth.ReportedAtUtc)</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportOnlinePeers"]</div><div class="hid-detail-value">@GetTransportOnlinePeerCount(_transportHealth)</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportPendingAcks"]</div><div class="hid-detail-value">@GetTransportMetricValue(_transportHealth, "pendingAckCount")</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportPeerState"]</div><div class="hid-detail-value">@GetTransportPeerState(_transportHealth)</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportPeerLastSeen"]</div><div class="hid-detail-value">@GetTransportPeerLastSeen(_transportHealth)</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportLastRelayAckAt"]</div><div class="hid-detail-value">@GetTransportLastRelayAckAt(_transportHealth)</div></div>
                            <div class="hid-detail-card"><div class="hid-detail-label">@T["TransportRoundtripMs"]</div><div class="hid-detail-value">@GetAckRoundtripMs(_transportHealth.LastCommandAck)</div></div>
                        </div>

                        @if (!string.Equals(GetTransportPeerFailureReason(_transportHealth), "—", StringComparison.Ordinal))
                        {
                            <div class="hid-meta-note">@T["TransportPeerFailureReason"]: @GetTransportPeerFailureReason(_transportHealth)</div>
                        }

                        @if (_transportHealth.LastPeerConsecutiveFailures.HasValue || _transportHealth.LastPeerReconnectBackoffMs.HasValue)
                        {
                            <div class="hid-meta-note">@T["TransportPeerStability"]: @GetTransportPeerStability(_transportHealth)</div>
                        }

                        @if (_transportHealth.LastCommandAck is null)
                        {
                            <div class="hid-empty-state">@T["NoTransportAckYet"]</div>
                        }
                        else
                        {
                            <div class="hid-detail-card">
                                <div class="hid-detail-label">@T["LastTransportAck"]</div>
                                <div class="hid-detail-value">@_transportHealth.LastCommandAck.Action -> @_transportHealth.LastCommandAck.Status</div>
                                <div class="hid-inline-meta">
                                    <span>@T["CommandId"]: @_transportHealth.LastCommandAck.CommandId</span>
                                    <span>@T["Channel"]: @_transportHealth.LastCommandAck.Channel</span>
                                    <span>@T["LastCommand"]: @FormatTime(_transportHealth.LastCommandAck.CompletedAtUtc ?? _transportHealth.LastCommandAck.CreatedAtUtc)</span>
                                    <span>@T["LastAckRoute"]: @GetAckRoute(_transportHealth.LastCommandAck)</span>
                                </div>
                                @if (_transportHealth.LastCommandAck.Error is not null)
                                {
                                    <div class="hid-meta-note">@_transportHealth.LastCommandAck.Error.Code · @_transportHealth.LastCommandAck.Error.Message</div>
                                    @if (_transportHealth.LastCommandAck.Error.Details is not null && _transportHealth.LastCommandAck.Error.Details.Count > 0)
                                    {
                                        <div class="hid-meta-note">@T["ErrorDetails"]: @FormatErrorDetails(_transportHealth.LastCommandAck.Error.Details)</div>
                                    }
                                }
                            </div>
                        }

                        <div>
                            <h4 class="hid-card-title">@T["WebRtcSignalInbox"]</h4>
                            @if (_webRtcSignals.Count == 0)
                            {
                                <div class="hid-empty-state">@T["NoWebRtcSignals"]</div>
                            }
                            else
                            {
                                <div class="hid-list-stack">
                                    @foreach (var signal in _webRtcSignals.Take(5))
                                    {
                                        <div class="hid-list-card">
                                            <div class="hid-list-card-header">
                                                <div>
                                                    <div class="hid-list-title">#@signal.Sequence · @signal.Kind</div>
                                                    <div class="hid-list-subtitle">@signal.SenderPeerId -> @(signal.RecipientPeerId ?? "*")</div>
                                                </div>
                                                <div class="hid-list-timestamp">@FormatTime(signal.CreatedAtUtc)</div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

                <div>
                    <div class="hid-panel-toolbar">
                        <div>
                            <h3 class="hid-card-title">@T["ControlOperationsPanel"]</h3>
                            <p class="hid-card-subtitle">@T["ControlArbitration"]</p>
                            <p class="hid-meta-note">@T["OperatorPrincipal"]: @CurrentOperatorPrincipalId</p>
                        </div>
                        <button class="hid-button-secondary" @onclick="RefreshAsync">@T["Refresh"]</button>
                    </div>

                    @if (_control.ActiveLease is null)
                    {
                        <div class="hid-empty-state">@T["NoActiveControlLease"]</div>
                    }
                    else
                    {
                        <div class="hid-lease-card">
                            <div class="hid-detail-label">@T["CurrentLease"]</div>
                            <div class="hid-detail-value">@_control.ActiveLease.PrincipalId</div>
                            <div class="hid-meta-note">@T["Participant"]: @_control.ActiveLease.ParticipantId</div>
                            <div class="hid-meta-note">@T["GrantedBy"]: @_control.ActiveLease.GrantedBy</div>
                            <div class="hid-meta-note">@T["LeaseExpires"]: @FormatTime(_control.ActiveLease.ExpiresAtUtc)</div>
                            <div class="hid-meta-note">@T["LeaseRemaining"]: @FormatLeaseRemaining(_control.ActiveLease.ExpiresAtUtc)</div>
                        </div>
                    }

                    <div class="hid-subtle-copy">@T["ControlRequestHelp"]</div>

                    <div class="hid-candidate-stack">
                        @foreach (var candidate in _control.Candidates)
                        {
                            <div class="hid-candidate-card">
                                <div class="hid-candidate-card-header">
                                    <div>
                                        <div class="hid-candidate-title">@candidate.PrincipalId</div>
                                        <div class="hid-list-subtitle">@candidate.ParticipantId · @candidate.Role</div>
                                    </div>
                                    <div class="hid-candidate-actions">
                                        <button class="hid-button-secondary hid-button-sm"
                                                disabled="@(!candidate.IsEligible || _busy)"
                                                @onclick="() => RequestControlAsync(candidate)">
                                            @T["RequestControl"]
                                        </button>
                                        <button class="hid-button-secondary hid-button-sm"
                                                disabled="@(_busy || !candidate.IsCurrentController || !CanRelease(candidate))"
                                                @onclick="() => ReleaseControlAsync(candidate)">
                                            @T["Release"]
                                        </button>
                                        <button class="hid-button-danger hid-button-sm"
                                                disabled="@(_busy || !_canModerate)"
                                                @onclick="() => ForceTakeoverAsync(candidate)">
                                            @T["ForceTakeover"]
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div>
                    <div class="hid-panel-toolbar">
                        <div>
                            <h3 class="hid-card-title">@T["CommandDeckTitle"]</h3>
                            <p class="hid-card-subtitle">@T["CommandDeckSubtitle"]</p>
                        </div>
                    </div>

                    <p class="hid-meta-note">@T["CommandDeckHint"]</p>

                    <div class="hid-form-grid">
                        <label class="hid-field">
                            <span class="hid-field-label">@T["CommandTextLabel"]</span>
                            <input class="hid-input" @bind="_demoCommandText" />
                        </label>
                        <label class="hid-field">
                            <span class="hid-field-label">@T["CommandShortcutLabel"]</span>
                            <input class="hid-input" @bind="_demoShortcut" />
                        </label>
                    </div>

                    <div class="hid-candidate-stack">
                        <div class="hid-candidate-card">
                            <div class="hid-candidate-card-header">
                                <div>
                                    <div class="hid-candidate-title">@T["CommandScenarioTextTitle"]</div>
                                    <div class="hid-list-subtitle">@T["CommandScenarioTextHelp"]</div>
                                </div>
                                <div class="hid-candidate-actions">
                                    <span class="@GetScenarioBadgeClass(CommandScenarioTextId)">@GetScenarioBadgeLabel(CommandScenarioTextId)</span>
                                    <button class="hid-button-primary hid-button-sm"
                                            disabled="@(_busy || string.IsNullOrWhiteSpace(_demoCommandText))"
                                            @onclick="SendDemoTextCommandAsync">
                                        @T["RunDemoScenario"]
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="hid-candidate-card">
                            <div class="hid-candidate-card-header">
                                <div>
                                    <div class="hid-candidate-title">@T["CommandScenarioShortcutTitle"]</div>
                                    <div class="hid-list-subtitle">@T["CommandScenarioShortcutHelp"]</div>
                                </div>
                                <div class="hid-candidate-actions">
                                    <span class="@GetScenarioBadgeClass(CommandScenarioShortcutId)">@GetScenarioBadgeLabel(CommandScenarioShortcutId)</span>
                                    <button class="hid-button-secondary hid-button-sm"
                                            disabled="@(_busy || string.IsNullOrWhiteSpace(_demoShortcut))"
                                            @onclick="SendDemoShortcutCommandAsync">
                                        @T["RunDemoScenario"]
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="hid-candidate-card">
                            <div class="hid-candidate-card-header">
                                <div>
                                    <div class="hid-candidate-title">@T["CommandScenarioMouseTitle"]</div>
                                    <div class="hid-list-subtitle">@T["CommandScenarioMouseHelp"]</div>
                                </div>
                                <div class="hid-candidate-actions">
                                    <span class="@GetScenarioBadgeClass(CommandScenarioMouseId)">@GetScenarioBadgeLabel(CommandScenarioMouseId)</span>
                                    <button class="hid-button-secondary hid-button-sm"
                                            disabled="@_busy"
                                            @onclick="SendDemoMouseMoveCommandAsync">
                                        @T["RunDemoScenario"]
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (_lastCommandAck is not null)
                    {
                        <div class="hid-detail-card">
                            <div class="hid-detail-label">@T["LastCommandAck"]</div>
                            <div class="hid-detail-value">@_lastCommandAck.Status</div>
                            <div class="hid-meta-note">@T["CommandId"]: @_lastCommandAck.CommandId</div>
                            @if (_lastCommandAck.Error is not null)
                            {
                                <div class="hid-meta-note">@_lastCommandAck.Error.Code · @_lastCommandAck.Error.Message</div>
                            }
                        </div>
                    }

                    <div>
                        <h4 class="hid-card-title">@T["CommandAuditTrailTitle"]</h4>
                        <div class="hid-list-stack">
                            @if (_commandAuditTrail.Count == 0)
                            {
                                <div class="hid-empty-state">@T["CommandAuditTrailEmpty"]</div>
                            }
                            else
                            {
                                @foreach (var entry in _commandAuditTrail)
                                {
                                    <div class="hid-list-card">
                                        <div class="hid-list-card-header hid-list-card-header--center">
                                            <div>
                                                <div class="hid-list-title">@entry.ScenarioName</div>
                                                <div class="hid-list-subtitle">@entry.Detail</div>
                                            </div>
                                            <div class="hid-candidate-actions">
                                                <span class="@GetTrailBadgeClass(entry)">@GetTrailBadgeLabel(entry)</span>
                                                <div class="hid-list-timestamp">@FormatTime(entry.OccurredAtUtc)</div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </section>

            <section class="hid-section-block">
                <div>
                    <h3 class="hid-card-title">@T["InvitationModerationPanel"]</h3>
                    <p class="hid-card-subtitle">@T["InvitationLobby"]</p>
                    <p class="hid-meta-note">@T["InvitationLobbyHelp"]</p>
                </div>

                <div class="hid-card-soft">
                    <div class="hid-panel-toolbar">
                        <div>
                            <h3 class="hid-card-title">@T["InviteParticipantTitle"]</h3>
                            <p class="hid-card-subtitle">@T["InviteParticipantHelp"]</p>
                        </div>
                    </div>
                    <div class="hid-form-grid">
                        <label class="hid-field">
                            <span class="hid-field-label">@T["Principal"]</span>
                            <input class="hid-input"
                                   @bind="_shareRequest.PrincipalId"
                                   placeholder="operator@example.com"
                                   readonly="@(!_canModerate)" />
                        </label>
                        <label class="hid-field">
                            <span class="hid-field-label">@T["Role"]</span>
                            <select class="hid-input" @bind="_shareRequest.Role">
                                @foreach (var role in SessionRoles)
                                {
                                    <option value="@role">@role</option>
                                }
                            </select>
                        </label>
                    </div>
                    <div class="hid-candidate-actions">
                        <button class="hid-button-primary hid-button-sm"
                                disabled="@(_busy || !_canModerate || string.IsNullOrWhiteSpace(EffectiveSharePrincipalId))"
                                @onclick="GrantShareAsync">
                            @T["GrantInvite"]
                        </button>
                        <button class="hid-button-secondary hid-button-sm"
                                disabled="@(_busy || string.IsNullOrWhiteSpace(EffectiveSharePrincipalId))"
                                @onclick="RequestInvitationAsync">
                            @T["RequestInvite"]
                        </button>
                    </div>
                    <div class="hid-subtle-copy">@T["InviteParticipantNote"]</div>
                </div>

                <div class="hid-candidate-stack">
                    @if (_lobby.Requested.Count == 0)
                    {
                        <div class="hid-empty-state">@T["NoRequestedInvitations"]</div>
                    }
                    else
                    {
                        @foreach (var invitation in _lobby.Requested)
                        {
                            <div class="hid-candidate-card">
                                <div class="hid-candidate-card-header">
                                    <div>
                                        <div class="hid-candidate-title">@invitation.PrincipalId</div>
                                        <div class="hid-list-subtitle">@invitation.ShareId · @T["Requested"] @invitation.Role</div>
                                    </div>
                                    <div class="hid-candidate-actions">
                                        <button class="hid-button-primary hid-button-sm"
                                                disabled="@(!_canModerate || _busy)"
                                                @onclick="() => ApproveInvitationAsync(invitation)">
                                            @T["Approve"]
                                        </button>
                                        <button class="hid-button-danger hid-button-sm"
                                                disabled="@(!_canModerate || _busy)"
                                                @onclick="() => DeclineInvitationAsync(invitation)">
                                            @T["Decline"]
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>

                <div>
                    <h3 class="hid-card-title">@T["PendingAccepted"]</h3>
                    <div class="hid-list-stack">
                        @foreach (var invitation in _lobby.Pending.Concat(_lobby.Accepted).Take(8))
                        {
                            <div class="hid-list-card">
                                <div class="hid-list-card-header">
                                    <div>
                                        <div class="hid-list-title">@invitation.PrincipalId</div>
                                        <div class="hid-list-subtitle">@invitation.Status · @invitation.Role</div>
                                    </div>
                                    <div class="hid-candidate-actions">
                                        @if (CanAcceptInvitation(invitation))
                                        {
                                            <button class="hid-button-primary hid-button-sm"
                                                    disabled="@_busy"
                                                    @onclick="() => AcceptShareAsync(invitation)">
                                                @T["Accept"]
                                            </button>
                                            <button class="hid-button-secondary hid-button-sm"
                                                    disabled="@_busy"
                                                    @onclick="() => RejectShareAsync(invitation)">
                                                @T["Reject"]
                                            </button>
                                        }
                                        @if (CanRevokeInvitation(invitation))
                                        {
                                            <button class="hid-button-danger hid-button-sm"
                                                    disabled="@_busy"
                                                    @onclick="() => RevokeShareAsync(invitation)">
                                                @T["Revoke"]
                                            </button>
                                        }
                                        <div class="hid-list-timestamp">@FormatTime(invitation.UpdatedAtUtc)</div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </section>

            <section class="hid-section-block">
                <div>
                    <h3 class="hid-card-title">@T["SessionRoomParticipants"]</h3>
                    <p class="hid-card-subtitle">@T["SessionRoomParticipantsHelp"]</p>
                </div>

                <div class="hid-list-stack">
                    @if (participants.Count == 0)
                    {
                        <div class="hid-empty-state">@T["NoParticipantsYet"]</div>
                    }
                    else
                    {
                        @foreach (var participant in participants)
                        {
                            <div class="hid-list-card">
                                <div class="hid-list-card-header">
                                    <div>
                                        <div class="hid-list-title">@participant.PrincipalId</div>
                                        <div class="hid-list-subtitle">@BuildParticipantSubtitle(participant)</div>
                                    </div>
                                    <div class="hid-list-side">
                                        <div class="hid-list-title">@participant.CommandCount @T["Commands"]</div>
                                        <div class="hid-list-subtitle">@T["FailedCommands"]: @participant.FailedCommandCount</div>
                                    </div>
                                </div>
                                <div class="hid-inline-meta">
                                    <span>@T["JoinedAt"]: @FormatTime(participant.JoinedAtUtc)</span>
                                    <span>@T["LastCommand"]: @FormatTime(participant.LastCommandAtUtc)</span>
                                    <span>@T["CurrentController"]: @(participant.IsCurrentController ? T["Yes"] : T["No"])</span>
                                </div>
                            </div>
                        }
                    }
                </div>

                <div>
                    <div class="hid-panel-toolbar">
                        <div>
                            <h3 class="hid-card-title">@T["SessionTimeline"]</h3>
                            <p class="hid-card-subtitle">@T["SessionTimelineHelp"]</p>
                        </div>
                        <div class="hid-meta-note">@T["Events"]: @timeline.TotalEntries</div>
                    </div>

                    <div class="hid-list-stack">
                        @if (timeline.Entries.Count == 0)
                        {
                            <div class="hid-empty-state">@T["NoTimelineEntries"]</div>
                        }
                        else
                        {
                            @foreach (var entry in timeline.Entries.Take(12))
                            {
                                <div class="hid-list-card">
                                    <div class="hid-list-card-header">
                                        <div>
                                            <div class="hid-list-title">@entry.Title</div>
                                            <div class="hid-list-subtitle">@entry.Kind</div>
                                        </div>
                                        <div class="hid-list-timestamp">@FormatTime(entry.OccurredAtUtc)</div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </section>
        </div>
    }
</section>

@code {
    [Parameter]
    public string SessionId { get; set; } = string.Empty;

    private SessionDashboardViewModel? _dashboard;
    private ControlDashboardViewModel? _control;
    private SessionLobbyViewModel? _lobby;
    private IReadOnlyList<ParticipantActivityViewModel>? _participants;
    private OperatorTimelineViewModel? _timeline;
    private SessionTransportHealthViewModel? _transportHealth;
    private IReadOnlyList<WebRtcSignalMessageViewModel> _webRtcSignals = [];
    private string? _transportHealthError;
    private string? _error;
    private string? _actionMessage;
    private AuthorizationDeniedViewModel? _denial;
    private string? _backendUnavailableMessage;
    private bool _busy;
    private SessionShareGrantRequestViewModel _shareRequest = new() { Role = "Observer" };
    private CommandAckViewModel? _lastCommandAck;
    private string _demoCommandText = "Hello from MicroMeet";
    private string _demoShortcut = "CTRL+ALT+M";
    private readonly Dictionary<string, CommandScenarioSnapshot> _commandScenarioSnapshots = new(StringComparer.OrdinalIgnoreCase);
    private readonly List<CommandAuditTrailEntry> _commandAuditTrail = [];
    private const int CommandAuditTrailCapacity = 6;
    private const string CommandScenarioTextId = "text";
    private const string CommandScenarioShortcutId = "shortcut";
    private const string CommandScenarioMouseId = "mouse";
    private static readonly string[] SessionRoles = ["Observer", "Controller", "Presenter"];
    private static readonly TimeSpan RecoveryStatePollInterval = TimeSpan.FromSeconds(3);
    private CancellationTokenSource? _recoveryPollingCts;
    private Task? _recoveryPollingTask;
    private bool _isRefreshing;

    private string CurrentOperatorPrincipalId => Identity.PrincipalId;
    private string EffectiveSharePrincipalId =>
        string.IsNullOrWhiteSpace(_shareRequest.PrincipalId)
            ? (CurrentOperatorPrincipalId?.Trim() ?? string.Empty)
            : _shareRequest.PrincipalId.Trim();
    private string SessionRoomUrl => Navigation.ToAbsoluteUri($"/sessions/{Uri.EscapeDataString(SessionId)}").ToString();

    private bool _canModerate => Identity.IsModerator
        || Identity.IsAdmin
        || string.Equals(CurrentOperatorPrincipalId, _dashboard?.RequestedBy, StringComparison.OrdinalIgnoreCase)
        || string.Equals(CurrentOperatorPrincipalId, _dashboard?.ActiveControllerPrincipalId, StringComparison.OrdinalIgnoreCase);

    private string NextRecommendedAction
    {
        get
        {
            if (_lobby is null || _dashboard is null)
            {
                return T["RoomNextObserve"];
            }

            if (_lobby.Requested.Count == 0 && _lobby.Pending.Count == 0 && _lobby.Accepted.Count == 0)
            {
                return T["RoomNextInvite"];
            }

            if (_canModerate && _lobby.Requested.Count > 0)
            {
                return T["RoomNextApprove"];
            }

            if (_lobby.Pending.Any(invitation => CanAcceptInvitation(invitation)))
            {
                return T["RoomNextAccept"];
            }

            if (_dashboard.ActiveControllers == 0 || _control?.ActiveLease is null)
            {
                return T["RoomNextControl"];
            }

            return T["RoomNextObserve"];
        }
    }

    private string ModerationAccessMessage => _canModerate
        ? T["ModerationAccessGranted"]
        : T["ModerationAccessDenied"];

    private string GetSessionFailedHint()
    {
        if (_dashboard is null)
        {
            return T["SessionFailedHint"];
        }

        if (_dashboard.FailedCommandCount > 0)
        {
            return string.Format(T["SessionFailedHintWithCommands"], _dashboard.FailedCommandCount);
        }

        if (_dashboard.LeaseExpiresAtUtc.HasValue)
        {
            return string.Format(T["SessionFailedHintWithLease"], FormatTime(_dashboard.LeaseExpiresAtUtc));
        }

        return T["SessionFailedHint"];
    }

    private string GetStateReasonLabel()
    {
        var reason = _dashboard?.StateReason;
        if (string.IsNullOrWhiteSpace(reason))
        {
            return T["StateReasonUnknown"];
        }

        return reason switch
        {
            "command_path_unstable" => T["StateReasonCommandPathUnstable"],
            "command_path_recovered" => T["StateReasonCommandPathRecovered"],
            "command_timeout" => T["StateReasonCommandTimeout"],
            "command_rejected" => T["StateReasonCommandRejected"],
            "lease_expired" => T["StateReasonLeaseExpired"],
            "lease_recovery_timeout" => T["StateReasonLeaseRecoveryTimeout"],
            "state_reconciled" => T["StateReasonReconciled"],
            _ => reason,
        };
    }

    protected override async Task OnParametersSetAsync()
    {
        EnsureShareRequestDefaults();
        EnsureRecoveryStatePollingStarted();
        await RefreshAsync();
    }

    private void EnsureRecoveryStatePollingStarted()
    {
        if (_recoveryPollingTask is not null)
        {
            return;
        }

        _recoveryPollingCts = new CancellationTokenSource();
        _recoveryPollingTask = RecoveryStatePollingLoopAsync(_recoveryPollingCts.Token);
    }

    private async Task RecoveryStatePollingLoopAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(RecoveryStatePollInterval);
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (_busy || !ShouldPollRecoveryState())
                {
                    continue;
                }

                await InvokeAsync(async () =>
                {
                    if (_busy || !ShouldPollRecoveryState())
                    {
                        return;
                    }

                    await RefreshAsync();
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
            // Expected during component disposal.
        }
    }

    private bool ShouldPollRecoveryState()
        => string.Equals(_dashboard?.State, "Recovering", StringComparison.OrdinalIgnoreCase)
           || string.Equals(_dashboard?.State, "Failed", StringComparison.OrdinalIgnoreCase);

    private async Task RefreshAsync()
    {
        if (_isRefreshing)
        {
            return;
        }

        try
        {
            _isRefreshing = true;
            _dashboard = await ApiClient.GetSessionDashboardAsync(SessionId);
            _control = await ApiClient.GetControlDashboardAsync(SessionId);
            _lobby = await ApiClient.GetLobbyAsync(SessionId);
            _participants = await ApiClient.GetParticipantActivityAsync(SessionId);
            _timeline = await ApiClient.GetOperatorTimelineAsync(SessionId, 20);
            await LoadTransportDiagnosticsAsync();
            EnsureShareRequestDefaults();
            _error = null;
            _denial = null;
            _backendUnavailableMessage = null;
        }
        catch (ControlPlaneApiUnavailableException exception)
        {
            _denial = null;
            _error = null;
            _backendUnavailableMessage = exception.Message;
        }
        catch (ControlPlaneApiException exception)
        {
            _denial = exception.AuthorizationDenied;
            _error = $"{T["SessionDetailsTitle"]}: {ResolveApiErrorMessage(exception)}";
            _backendUnavailableMessage = null;
        }
        catch (Exception exception)
        {
            _denial = null;
            _error = $"{T["SessionDetailsTitle"]}: {exception.Message}";
            _backendUnavailableMessage = null;
        }
        finally
        {
            _isRefreshing = false;
        }
    }

    private async Task LoadTransportDiagnosticsAsync()
    {
        try
        {
            _transportHealth = await ApiClient.GetSessionTransportHealthAsync(SessionId);
            _webRtcSignals = await ApiClient.GetWebRtcSignalsAsync(SessionId, limit: 12)
                ?? Array.Empty<WebRtcSignalMessageViewModel>();
            _transportHealthError = null;
        }
        catch (ControlPlaneApiUnavailableException exception)
        {
            _transportHealth = null;
            _webRtcSignals = [];
            _transportHealthError = exception.Message;
        }
        catch (ControlPlaneApiException exception)
        {
            _transportHealth = null;
            _webRtcSignals = [];
            _transportHealthError = ResolveApiErrorMessage(exception);
        }
        catch (Exception exception)
        {
            _transportHealth = null;
            _webRtcSignals = [];
            _transportHealthError = exception.Message;
        }
    }

    private async Task RequestControlAsync(ControlCandidateViewModel candidate)
        => await RunActionAsync(
            $"{T["ControlRequestedMessage"]} {candidate.PrincipalId}.",
            () => ApiClient.RequestControlAsync(SessionId, candidate.ParticipantId, CurrentOperatorPrincipalId, 30, "operator requested control"));

    private async Task ReleaseControlAsync(ControlCandidateViewModel candidate)
        => await RunActionAsync(
            $"{T["ControlReleasedMessage"]} {candidate.PrincipalId}.",
            () => ApiClient.ReleaseControlAsync(SessionId, candidate.ParticipantId, CurrentOperatorPrincipalId, "operator released control"));

    private async Task ForceTakeoverAsync(ControlCandidateViewModel candidate)
        => await RunActionAsync(
            $"{T["ControlTakeoverMessage"]} {candidate.PrincipalId}.",
            () => ApiClient.ForceTakeoverControlAsync(SessionId, candidate.ParticipantId, CurrentOperatorPrincipalId, 30, "operator takeover"));

    private async Task ApproveInvitationAsync(SessionShareViewModel invitation)
        => await RunActionAsync(
            $"{T["InvitationApprovedMessage"]} {invitation.ShareId}.",
            () => ApiClient.ApproveInvitationAsync(SessionId, invitation.ShareId, CurrentOperatorPrincipalId, invitation.Role, "approved in operator shell"));

    private async Task DeclineInvitationAsync(SessionShareViewModel invitation)
        => await RunActionAsync(
            $"{T["InvitationDeclinedMessage"]} {invitation.ShareId}.",
            () => ApiClient.DeclineInvitationAsync(SessionId, invitation.ShareId, CurrentOperatorPrincipalId, "declined in operator shell"));

    private async Task GrantShareAsync()
        => await RunActionAsync(
            string.Format(T["InviteGrantedMessage"], _shareRequest.PrincipalId),
            () => ApiClient.CreateShareAsync(
                SessionId,
                BuildShareRequest()));

    private async Task RequestInvitationAsync()
        => await RunActionAsync(
            string.Format(T["InviteRequestedMessage"], _shareRequest.PrincipalId),
            () => ApiClient.RequestInvitationAsync(
                SessionId,
                BuildInvitationRequest()));

    private async Task AcceptShareAsync(SessionShareViewModel invitation)
        => await RunActionAsync(
            $"{T["InvitationAcceptedMessage"]} {invitation.ShareId}.",
            () => ApiClient.AcceptShareAsync(
                SessionId,
                invitation.ShareId,
                CurrentOperatorPrincipalId,
                "accepted in session room",
                Identity.TenantId,
                Identity.OrganizationId,
                Identity.OperatorRoles));

    private async Task RejectShareAsync(SessionShareViewModel invitation)
        => await RunActionAsync(
            $"{T["InvitationRejectedMessage"]} {invitation.ShareId}.",
            () => ApiClient.RejectShareAsync(
                SessionId,
                invitation.ShareId,
                CurrentOperatorPrincipalId,
                "rejected in session room",
                Identity.TenantId,
                Identity.OrganizationId,
                Identity.OperatorRoles));

    private async Task RevokeShareAsync(SessionShareViewModel invitation)
        => await RunActionAsync(
            $"{T["InvitationRevokedMessage"]} {invitation.ShareId}.",
            () => ApiClient.RevokeShareAsync(
                SessionId,
                invitation.ShareId,
                CurrentOperatorPrincipalId,
                "revoked in session room",
                Identity.TenantId,
                Identity.OrganizationId,
                Identity.OperatorRoles));

    private Task SendDemoTextCommandAsync()
        => DispatchDemoCommandAsync(
            CommandScenarioTextId,
            T["CommandScenarioTextTitle"],
            "keyboard.text",
            string.Format(T["CommandDispatchedMessage"], "keyboard.text"),
            new KeyValuePair<string, object?>("text", _demoCommandText.Trim()));

    private Task SendDemoShortcutCommandAsync()
        => DispatchDemoCommandAsync(
            CommandScenarioShortcutId,
            T["CommandScenarioShortcutTitle"],
            "keyboard.shortcut",
            string.Format(T["CommandDispatchedMessage"], "keyboard.shortcut"),
            new KeyValuePair<string, object?>("shortcut", _demoShortcut.Trim()));

    private Task SendDemoMouseMoveCommandAsync()
        => DispatchDemoCommandAsync(
            CommandScenarioMouseId,
            T["CommandScenarioMouseTitle"],
            "mouse.move",
            string.Format(T["CommandDispatchedMessage"], "mouse.move"),
            new KeyValuePair<string, object?>("dx", 24),
            new KeyValuePair<string, object?>("dy", 12));

    private async Task DispatchDemoCommandAsync(
        string scenarioId,
        string scenarioName,
        string action,
        string successMessage,
        params KeyValuePair<string, object?>[] args)
    {
        try
        {
            _busy = true;
            _actionMessage = null;
            _error = null;
            _denial = null;
            _backendUnavailableMessage = null;

            var participantId = ResolveCurrentParticipantId();
            var payload = BuildCommandRequest(action, args, participantId);
            _lastCommandAck = await ApiClient.DispatchCommandAsync(SessionId, payload);

            var resolvedAck = _lastCommandAck ?? new CommandAckViewModel(payload.CommandId, "Unknown");
            var accepted = IsAcceptedCommandAck(resolvedAck.Status);
            var detail = resolvedAck.Error is null
                ? $"{action} -> {resolvedAck.Status}"
                : $"{resolvedAck.Error.Code}: {resolvedAck.Error.Message}";

            RegisterCommandScenarioResult(scenarioId, scenarioName, resolvedAck.Status, accepted, detail);
            _actionMessage = accepted
                ? successMessage
                : string.Format(T["CommandRejectedMessage"], action, resolvedAck.Status);

            await RefreshAsync();
            ResetDrafts();
        }
        catch (ControlPlaneApiUnavailableException exception)
        {
            _denial = null;
            _error = null;
            _backendUnavailableMessage = exception.Message;
            RegisterCommandScenarioResult(scenarioId, scenarioName, "Unavailable", false, exception.Message);
        }
        catch (ControlPlaneApiException exception)
        {
            _denial = exception.AuthorizationDenied;
            _error = ResolveApiErrorMessage(exception);
            _backendUnavailableMessage = null;
            var detail = exception.AuthorizationDenied?.Message ?? ResolveApiErrorMessage(exception);
            RegisterCommandScenarioResult(scenarioId, scenarioName, "Rejected", false, detail);
        }
        catch (Exception exception)
        {
            _denial = null;
            _error = exception.Message;
            _backendUnavailableMessage = null;
            RegisterCommandScenarioResult(scenarioId, scenarioName, "Rejected", false, exception.Message);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task EndSessionAsync()
    {
        try
        {
            _busy = true;
            _actionMessage = null;
            _error = null;
            _denial = null;
            _backendUnavailableMessage = null;

            await ApiClient.CloseSessionAsync(SessionId, $"closed by {CurrentOperatorPrincipalId}");
            Navigation.NavigateTo("/", forceLoad: false);
        }
        catch (ControlPlaneApiUnavailableException exception)
        {
            _denial = null;
            _error = null;
            _backendUnavailableMessage = exception.Message;
        }
        catch (ControlPlaneApiException exception)
        {
            _denial = exception.AuthorizationDenied;
            _error = ResolveApiErrorMessage(exception);
            _backendUnavailableMessage = null;
        }
        catch (Exception exception)
        {
            _denial = null;
            _error = exception.Message;
            _backendUnavailableMessage = null;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RunActionAsync(string successMessage, Func<Task> action)
    {
        try
        {
            _busy = true;
            _actionMessage = null;
            _error = null;
            _denial = null;
            _backendUnavailableMessage = null;
            await action();
            _actionMessage = successMessage;
            await RefreshAsync();
            ResetDrafts();
        }
        catch (ControlPlaneApiUnavailableException exception)
        {
            _denial = null;
            _error = null;
            _backendUnavailableMessage = exception.Message;
        }
        catch (ControlPlaneApiException exception)
        {
            _denial = exception.AuthorizationDenied;
            _error = ResolveApiErrorMessage(exception);
            _backendUnavailableMessage = null;
        }
        catch (Exception exception)
        {
            _denial = null;
            _error = exception.Message;
            _backendUnavailableMessage = null;
        }
        finally
        {
            _busy = false;
        }
    }

    private SessionCommandDispatchRequestViewModel BuildCommandRequest(
        string action,
        IReadOnlyList<KeyValuePair<string, object?>> args,
        string? participantId)
    {
        var commandArgs = new Dictionary<string, object?>(StringComparer.OrdinalIgnoreCase)
        {
            ["principalId"] = CurrentOperatorPrincipalId,
        };

        if (!string.IsNullOrWhiteSpace(participantId))
        {
            commandArgs["participantId"] = participantId;
        }

        foreach (var arg in args)
        {
            commandArgs[arg.Key] = arg.Value;
        }

        return new SessionCommandDispatchRequestViewModel
        {
            CommandId = $"cmd-{Guid.NewGuid():N}",
            Channel = "Hid",
            Action = action,
            Args = commandArgs,
            TimeoutMs = 3000,
            IdempotencyKey = $"idem-{Guid.NewGuid():N}",
            TenantId = Identity.TenantId,
            OrganizationId = Identity.OrganizationId,
            OperatorRoles = Identity.OperatorRoles,
        };
    }

    private string GetScenarioBadgeLabel(string scenarioId)
        => _commandScenarioSnapshots.TryGetValue(scenarioId, out var snapshot)
            ? (snapshot.Accepted ? T["ScenarioPass"] : T["ScenarioReject"])
            : T["ScenarioNotRun"];

    private string GetScenarioBadgeClass(string scenarioId)
        => _commandScenarioSnapshots.TryGetValue(scenarioId, out var snapshot)
            ? (snapshot.Accepted ? "hid-badge hid-badge--positive" : "hid-badge hid-badge--danger")
            : "hid-badge hid-badge--warning";

    private string GetTrailBadgeLabel(CommandAuditTrailEntry entry)
        => entry.Accepted ? T["ScenarioPass"] : T["ScenarioReject"];

    private static string GetTrailBadgeClass(CommandAuditTrailEntry entry)
        => entry.Accepted ? "hid-badge hid-badge--positive" : "hid-badge hid-badge--danger";

    private void RegisterCommandScenarioResult(
        string scenarioId,
        string scenarioName,
        string ackStatus,
        bool accepted,
        string detail)
    {
        var occurredAtUtc = DateTimeOffset.UtcNow;
        _commandScenarioSnapshots[scenarioId] = new CommandScenarioSnapshot(ackStatus, accepted, detail, occurredAtUtc);

        _commandAuditTrail.Insert(0, new CommandAuditTrailEntry(scenarioName, ackStatus, accepted, detail, occurredAtUtc));
        if (_commandAuditTrail.Count > CommandAuditTrailCapacity)
        {
            _commandAuditTrail.RemoveRange(CommandAuditTrailCapacity, _commandAuditTrail.Count - CommandAuditTrailCapacity);
        }
    }

    private static bool IsAcceptedCommandAck(string? status)
        => string.Equals(status, "Accepted", StringComparison.OrdinalIgnoreCase)
           || string.Equals(status, "Applied", StringComparison.OrdinalIgnoreCase);

    private string? ResolveCurrentParticipantId()
    {
        var inControlCandidates = _control?.Candidates
            .FirstOrDefault(candidate => string.Equals(candidate.PrincipalId, CurrentOperatorPrincipalId, StringComparison.OrdinalIgnoreCase))
            ?.ParticipantId;
        if (!string.IsNullOrWhiteSpace(inControlCandidates))
        {
            return inControlCandidates;
        }

        return _participants?
            .FirstOrDefault(participant => string.Equals(participant.PrincipalId, CurrentOperatorPrincipalId, StringComparison.OrdinalIgnoreCase))
            ?.ParticipantId;
    }

    private static string BuildParticipantSubtitle(ParticipantActivityViewModel participant)
    {
        var shareStatusSuffix = participant.DerivedFromShare && !string.IsNullOrWhiteSpace(participant.ShareStatus)
            ? $" · share:{participant.ShareStatus}"
            : string.Empty;
        return $"{participant.ParticipantId} · {participant.Role}{shareStatusSuffix}";
    }

    private bool CanRelease(ControlCandidateViewModel candidate)
        => string.Equals(candidate.PrincipalId, CurrentOperatorPrincipalId, StringComparison.OrdinalIgnoreCase) || _canModerate;

    private bool CanAcceptInvitation(SessionShareViewModel invitation)
        => string.Equals(invitation.Status, "Pending", StringComparison.OrdinalIgnoreCase)
           && string.Equals(invitation.PrincipalId, CurrentOperatorPrincipalId, StringComparison.OrdinalIgnoreCase);

    private bool CanRevokeInvitation(SessionShareViewModel invitation)
        => _canModerate
           && (string.Equals(invitation.Status, "Pending", StringComparison.OrdinalIgnoreCase)
               || string.Equals(invitation.Status, "Accepted", StringComparison.OrdinalIgnoreCase));

    private SessionShareGrantRequestViewModel BuildShareRequest()
        => new()
        {
            ShareId = BuildShareId("share"),
            PrincipalId = EffectiveSharePrincipalId,
            GrantedBy = CurrentOperatorPrincipalId,
            Role = _shareRequest.Role,
            TenantId = Identity.TenantId,
            OrganizationId = Identity.OrganizationId,
            OperatorRoles = Identity.OperatorRoles,
        };

    private SessionInvitationRequestViewModel BuildInvitationRequest()
        => new()
        {
            ShareId = BuildShareId("invite"),
            PrincipalId = EffectiveSharePrincipalId,
            RequestedBy = CurrentOperatorPrincipalId,
            RequestedRole = _shareRequest.Role,
            Message = "requested in session room",
            TenantId = Identity.TenantId,
            OrganizationId = Identity.OrganizationId,
            OperatorRoles = Identity.OperatorRoles,
        };

    private void ResetDrafts()
    {
        _shareRequest = new SessionShareGrantRequestViewModel
        {
            PrincipalId = CurrentOperatorPrincipalId,
            Role = "Observer",
        };
    }

    private void EnsureShareRequestDefaults()
    {
        if (string.IsNullOrWhiteSpace(_shareRequest.PrincipalId)
            && !string.IsNullOrWhiteSpace(CurrentOperatorPrincipalId))
        {
            _shareRequest.PrincipalId = CurrentOperatorPrincipalId.Trim();
        }
    }

    private static string BuildShareId(string prefix)
    {
        var shareId = $"{prefix}-{Guid.NewGuid():N}";
        return shareId.Length <= 48 ? shareId : shareId[..48];
    }

    private string ResolveApiErrorMessage(ControlPlaneApiException exception)
    {
        if (exception.ControlConflict is null)
        {
            return exception.Message;
        }

        return BuildControlConflictMessage(exception.ControlConflict);
    }

    private string BuildControlConflictMessage(ControlArbitrationConflictViewModel conflict)
    {
        var requestedParticipant = conflict.RequestedParticipantId ?? "—";
        var activeParticipant = conflict.CurrentController?.ParticipantId ?? "—";
        var activePrincipal = conflict.CurrentController?.PrincipalId ?? "—";
        var leaseExpires = FormatTime(conflict.CurrentController?.ExpiresAtUtc);

        return conflict.Code switch
        {
            "E_CONTROL_LEASE_HELD_BY_OTHER" => string.Format(T["ControlConflictLeaseHeldByOther"], activePrincipal, leaseExpires),
            "E_CONTROL_PARTICIPANT_MISMATCH" => string.Format(T["ControlConflictParticipantMismatch"], activeParticipant, requestedParticipant),
            "E_CONTROL_NOT_ELIGIBLE" => string.Format(T["ControlConflictNotEligible"], requestedParticipant),
            _ => string.Format(T["ControlConflictGeneric"], conflict.Error, conflict.Code),
        };
    }

    private string FormatLeaseRemaining(DateTimeOffset expiresAtUtc)
    {
        var remaining = expiresAtUtc - DateTimeOffset.UtcNow;
        if (remaining <= TimeSpan.Zero)
        {
            return T["LeaseExpiredNow"];
        }

        if (remaining.TotalMinutes >= 1)
        {
            return string.Format(
                T["LeaseRemainingMinutesSeconds"],
                (int)remaining.TotalMinutes,
                Math.Max(0, remaining.Seconds));
        }

        return string.Format(T["LeaseRemainingSeconds"], Math.Max(1, (int)Math.Ceiling(remaining.TotalSeconds)));
    }

    private static string GetTransportMetricValue(SessionTransportHealthViewModel? health, string key)
    {
        if (health?.Metrics is null || !health.Metrics.TryGetValue(key, out var value) || value is null)
        {
            return "—";
        }

        return ConvertMetricObjectToString(value);
    }

    /// <summary>
    /// Resolves online relay peer count with typed-field preference and metric fallback.
    /// </summary>
    private static string GetTransportOnlinePeerCount(SessionTransportHealthViewModel? health)
    {
        if (health?.OnlinePeerCount is not null)
        {
            return health.OnlinePeerCount.Value.ToString(CultureInfo.InvariantCulture);
        }

        return GetTransportMetricValue(health, "onlinePeerCount");
    }

    /// <summary>
    /// Resolves relay peer state with typed-field preference and metric fallback.
    /// </summary>
    private static string GetTransportPeerState(SessionTransportHealthViewModel? health)
    {
        if (!string.IsNullOrWhiteSpace(health?.LastPeerState))
        {
            return health.LastPeerState!;
        }

        return GetTransportMetricValue(health, "lastPeerState");
    }

    /// <summary>
    /// Resolves relay peer failure reason with typed-field preference and metric fallback.
    /// </summary>
    private static string GetTransportPeerFailureReason(SessionTransportHealthViewModel? health)
    {
        if (!string.IsNullOrWhiteSpace(health?.LastPeerFailureReason))
        {
            return health.LastPeerFailureReason!;
        }

        return GetTransportMetricValue(health, "lastPeerFailureReason");
    }

    /// <summary>
    /// Formats relay peer last-seen timestamp.
    /// </summary>
    private string GetTransportPeerLastSeen(SessionTransportHealthViewModel? health)
    {
        if (health?.LastPeerSeenAtUtc is not null)
        {
            return FormatTime(health.LastPeerSeenAtUtc);
        }

        return "—";
    }

    /// <summary>
    /// Formats relay last-ack timestamp.
    /// </summary>
    private string GetTransportLastRelayAckAt(SessionTransportHealthViewModel? health)
    {
        if (health?.LastRelayAckAtUtc is not null)
        {
            return FormatTime(health.LastRelayAckAtUtc);
        }

        return "—";
    }

    /// <summary>
    /// Builds compact relay stability diagnostics from typed peer-health fields.
    /// </summary>
    private static string GetTransportPeerStability(SessionTransportHealthViewModel? health)
    {
        if (health is null)
        {
            return "—";
        }

        var parts = new List<string>();
        if (health.LastPeerConsecutiveFailures.HasValue)
        {
            parts.Add($"failures={health.LastPeerConsecutiveFailures.Value.ToString(CultureInfo.InvariantCulture)}");
        }

        if (health.LastPeerReconnectBackoffMs.HasValue)
        {
            parts.Add($"backoffMs={health.LastPeerReconnectBackoffMs.Value.ToString(CultureInfo.InvariantCulture)}");
        }

        return parts.Count == 0 ? "—" : string.Join(", ", parts);
    }

    private static string GetAckRoute(CommandJournalEntryViewModel? ack)
    {
        if (ack?.Metrics is null)
        {
            return "—";
        }

        if (ack.Metrics.TryGetValue("transportRelayMode", out var relayMode) && relayMode >= 1)
        {
            return "webrtc-relay";
        }

        if (ack.Metrics.TryGetValue("transportBridgeMode", out var bridgeMode) && bridgeMode >= 1)
        {
            return "connector-bridge";
        }

        return "direct";
    }

    private static string GetAckRoundtripMs(CommandJournalEntryViewModel? ack)
    {
        if (ack?.Metrics is null)
        {
            return "—";
        }

        if (ack.Metrics.TryGetValue("relayAdapterWsRoundtripMs", out var relayMs))
        {
            return $"{relayMs:0.##}";
        }

        if (ack.Metrics.TryGetValue("deviceAckMs", out var deviceAckMs))
        {
            return $"{deviceAckMs:0.##}";
        }

        return "—";
    }

    private static string FormatErrorDetails(IReadOnlyDictionary<string, object?>? details)
    {
        if (details is null || details.Count == 0)
        {
            return "—";
        }

        return string.Join(
            ", ",
            details.Select(pair => $"{pair.Key}={ConvertMetricObjectToString(pair.Value)}"));
    }

    private static string ConvertMetricObjectToString(object? value)
    {
        if (value is null)
        {
            return "—";
        }

        if (value is JsonElement element)
        {
            return element.ValueKind switch
            {
                JsonValueKind.String => element.GetString() ?? "—",
                JsonValueKind.Number => element.GetRawText(),
                JsonValueKind.True => "true",
                JsonValueKind.False => "false",
                JsonValueKind.Null => "—",
                _ => element.GetRawText(),
            };
        }

        return value.ToString() ?? "—";
    }

    private static string FormatTime(DateTimeOffset? value)
        => value?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "—";

    public async ValueTask DisposeAsync()
    {
        if (_recoveryPollingCts is null)
        {
            return;
        }

        _recoveryPollingCts.Cancel();

        if (_recoveryPollingTask is not null)
        {
            try
            {
                await _recoveryPollingTask;
            }
            catch (OperationCanceledException)
            {
                // Expected during component disposal.
            }
        }

        _recoveryPollingCts.Dispose();
        _recoveryPollingCts = null;
    }

