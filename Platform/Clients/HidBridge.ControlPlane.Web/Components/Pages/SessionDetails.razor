    private string FormatBooleanMetricLabel(string raw)
    {
        if (string.IsNullOrWhiteSpace(raw) || string.Equals(raw, "—", StringComparison.Ordinal))
        {
            return "—";
        }

        if (string.Equals(raw, "1", StringComparison.OrdinalIgnoreCase))
        {
            return T["Yes"];
        }

        if (string.Equals(raw, "0", StringComparison.OrdinalIgnoreCase))
        {
            return T["No"];
        }

        if (bool.TryParse(raw, out var parsed))
        {
            return parsed ? T["Yes"] : T["No"];
        }

        return raw;
    }

    /// <summary>
    /// Formats one compact media video descriptor string.
    /// </summary>
    private static string FormatMediaVideoDescriptor(MediaVideoDescriptorViewModel descriptor)
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(descriptor.Codec))
        {
            parts.Add(descriptor.Codec!);
        }

        if (descriptor.Width.HasValue || descriptor.Height.HasValue)
        {
            var width = descriptor.Width?.ToString(CultureInfo.InvariantCulture) ?? "?";
            var height = descriptor.Height?.ToString(CultureInfo.InvariantCulture) ?? "?";
            parts.Add($"{width}x{height}");
        }

        if (descriptor.FrameRate.HasValue)
        {
            parts.Add($"{descriptor.FrameRate.Value.ToString("0.##", CultureInfo.InvariantCulture)} fps");
        }

        if (descriptor.BitrateKbps.HasValue)
        {
            parts.Add($"{descriptor.BitrateKbps.Value.ToString(CultureInfo.InvariantCulture)} kbps");
        }

        return parts.Count == 0 ? "—" : string.Join(" · ", parts);
    }

