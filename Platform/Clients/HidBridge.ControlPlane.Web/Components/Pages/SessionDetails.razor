@code {
    [Parameter]
    public string SessionId { get; set; } = string.Empty;

    private SessionDashboardViewModel? _dashboard;
    private ControlDashboardViewModel? _control;
    private SessionLobbyViewModel? _lobby;
    private IReadOnlyList<ParticipantActivityViewModel>? _participants;
    private OperatorTimelineViewModel? _timeline;
    private SessionTransportReadinessViewModel? _transportReadiness;
    private SessionTransportHealthViewModel? _transportHealth;
    private IReadOnlyList<WebRtcSignalMessageViewModel> _webRtcSignals = [];
    private string? _transportHealthError;
    private string? _error;
    private string? _actionMessage;
    private AuthorizationDeniedViewModel? _denial;
    private string? _backendUnavailableMessage;
    private bool _busy;
    private SessionShareGrantRequestViewModel _shareRequest = new() { Role = "Observer" };
    private CommandAckViewModel? _lastCommandAck;
    private string _demoCommandText = "Hello from MicroMeet";
    private string _demoShortcut = "CTRL+ALT+M";
    private int _demoMouseDx = 24;
    private int _demoMouseDy = 12;
    private int _demoMouseWheelDelta = 1;
    private string _demoMouseButton = "left";
    private int _demoKeyboardUsage = 4;
    private int _demoKeyboardModifiers;
    private readonly Dictionary<string, CommandScenarioSnapshot> _commandScenarioSnapshots = new(StringComparer.OrdinalIgnoreCase);
    private readonly List<CommandAuditTrailEntry> _commandAuditTrail = [];
    private DotNetObjectReference<SessionDetails>? _liveInputDotNetRef;
    private IJSObjectReference? _liveInputModule;
    private bool _liveControlEnabled;
    private bool _pointerLockEnabled;
    private bool _liveControlAutoArmRequested;
    private const int CommandAuditTrailCapacity = 6;
    private const string CommandScenarioTextId = "text";
    private const string CommandScenarioShortcutId = "shortcut";
    private const string CommandScenarioMouseId = "mouse";
    private const string CommandScenarioMouseClickId = "mouse-click";
    private const string CommandScenarioMouseWheelId = "mouse-wheel";
    private const string CommandScenarioMouseButtonDownId = "mouse-button-down";
    private const string CommandScenarioMouseButtonUpId = "mouse-button-up";
    private const string CommandScenarioKeyboardPressId = "keyboard-press";
    private const string CommandScenarioKeyboardResetId = "keyboard-reset";
    private static readonly string[] SessionRoles = ["Observer", "Controller", "Presenter"];
    private static readonly TimeSpan RecoveryStatePollInterval = TimeSpan.FromSeconds(3);
    private CancellationTokenSource? _recoveryPollingCts;
    private Task? _recoveryPollingTask;
    private bool _isRefreshing;

    private string CurrentOperatorPrincipalId => Identity.PrincipalId;
    private string EffectiveSharePrincipalId =>
        string.IsNullOrWhiteSpace(_shareRequest.PrincipalId)
            ? (CurrentOperatorPrincipalId?.Trim() ?? string.Empty)
            : _shareRequest.PrincipalId.Trim();
    private string SessionRoomUrl => Navigation.ToAbsoluteUri($"/sessions/{Uri.EscapeDataString(SessionId)}").ToString();

    private bool _canModerate => Identity.IsModerator
        || Identity.IsAdmin
        || string.Equals(CurrentOperatorPrincipalId, _dashboard?.RequestedBy, StringComparison.OrdinalIgnoreCase)
        || string.Equals(CurrentOperatorPrincipalId, _dashboard?.ActiveControllerPrincipalId, StringComparison.OrdinalIgnoreCase);

    private bool _isLiveControlAvailable
        => IsSessionActiveForControl()
           && !string.IsNullOrWhiteSpace(CurrentOperatorPrincipalId)
           && string.Equals(CurrentOperatorPrincipalId, _control?.ActiveLease?.PrincipalId, StringComparison.OrdinalIgnoreCase);

    private string GetLiveControlBlockedHint()
        => GetControlBlockedDiagnostic() is { } diagnostic
            ? string.Format(T["ControlBlockedBannerWithCode"], diagnostic.Code, diagnostic.Message)
            : T["LiveControlUnavailableHint"];

    private string GetLiveControlPathStatus()
    {
        if (_isLiveControlAvailable)
        {
            return _liveControlEnabled
                ? T["LiveControlPathReadyCapturing"]
                : T["LiveControlPathReadyLease"];
        }

        if (GetControlBlockedDiagnostic() is { } blocked)
        {
            return $"{blocked.Code}: {blocked.Message}";
        }

        return T["LiveControlPathNotReady"];
    }

    private ControlBlockDiagnostic? GetControlBlockedDiagnostic()
    {
        var sessionBlock = ResolveSessionControlBlockReason();
        if (sessionBlock is not null)
        {
            return sessionBlock;
        }

        return ResolveLeaseControlBlockReason();
    }

    private ControlBlockDiagnostic? ResolveSessionControlBlockReason()
    {
        if (_transportReadiness is not null
            && string.Equals(_transportReadiness.ReasonCode, "session_not_active", StringComparison.OrdinalIgnoreCase))
        {
            var reasonCode = string.IsNullOrWhiteSpace(_transportReadiness.ReasonCode)
                ? "session_not_active"
                : _transportReadiness.ReasonCode;
            var reason = string.IsNullOrWhiteSpace(_transportReadiness.Reason)
                ? T["ControlBlockedSessionGeneric"]
                : _transportReadiness.Reason;
            return new ControlBlockDiagnostic(reasonCode, reason);
        }

        if (_dashboard is null)
        {
            return null;
        }

        if (string.Equals(_dashboard.State, "Failed", StringComparison.OrdinalIgnoreCase)
            || string.Equals(_dashboard.State, "Ended", StringComparison.OrdinalIgnoreCase)
            || string.Equals(_dashboard.State, "Terminating", StringComparison.OrdinalIgnoreCase))
        {
            return new ControlBlockDiagnostic(
                "session_state_blocked",
                string.Format(
                    T["ControlBlockedSessionState"],
                    _dashboard.State,
                    GetStateReasonLabel()));
        }

        return null;
    }

    private ControlBlockDiagnostic? ResolveLeaseControlBlockReason()
    {
        if (_control is null || _dashboard is null)
        {
            return null;
        }

        if (_control.ActiveLease is null)
        {
            return new ControlBlockDiagnostic("lease_missing", T["ControlBlockedLeaseMissing"]);
        }

        if (string.IsNullOrWhiteSpace(CurrentOperatorPrincipalId))
        {
            return new ControlBlockDiagnostic("operator_unknown", T["ControlBlockedOperatorUnknown"]);
        }

        if (!string.Equals(_control.ActiveLease.PrincipalId, CurrentOperatorPrincipalId, StringComparison.OrdinalIgnoreCase))
        {
            return new ControlBlockDiagnostic(
                "lease_held_by_other",
                string.Format(
                    T["ControlBlockedLeaseHeldBy"],
                    _control.ActiveLease.PrincipalId,
                    FormatTime(_control.ActiveLease.ExpiresAtUtc),
                    FormatLeaseRemaining(_control.ActiveLease.ExpiresAtUtc)));
        }

        return null;
    }

    private bool IsSessionActiveForControl()
    {
        if (_dashboard is null)
        {
            return false;
        }

        return !string.Equals(_dashboard.State, "Failed", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(_dashboard.State, "Ended", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(_dashboard.State, "Terminating", StringComparison.OrdinalIgnoreCase);
    }

    private ControlCandidateViewModel? FindCurrentOperatorCandidate()
        => _control?.Candidates
            .FirstOrDefault(candidate => string.Equals(candidate.PrincipalId, CurrentOperatorPrincipalId, StringComparison.OrdinalIgnoreCase));

    private bool CanQuickRequestControl()
    {
        if (_busy || !IsSessionActiveForControl())
        {
            return false;
        }

        var candidate = FindCurrentOperatorCandidate();
        return candidate is not null
            && candidate.IsEligible
            && !candidate.IsCurrentController;
    }

    private bool CanQuickForceTakeover()
    {
        if (_busy || !_canModerate || !IsSessionActiveForControl())
        {
            return false;
        }

        var candidate = FindCurrentOperatorCandidate();
        return candidate is not null;
    }

    private string NextRecommendedAction
    {
        get
        {
            if (_lobby is null || _dashboard is null)
            {
                return T["RoomNextObserve"];
            }

            if (_lobby.Requested.Count == 0 && _lobby.Pending.Count == 0 && _lobby.Accepted.Count == 0)
            {
                return T["RoomNextInvite"];
            }

            if (_canModerate && _lobby.Requested.Count > 0)
            {
                return T["RoomNextApprove"];
            }

            if (_lobby.Pending.Any(invitation => CanAcceptInvitation(invitation)))
            {
                return T["RoomNextAccept"];
            }

            if (_dashboard.ActiveControllers == 0 || _control?.ActiveLease is null)
            {
                return T["RoomNextControl"];
            }

            return T["RoomNextObserve"];
        }
    }

    private string ModerationAccessMessage => _canModerate
        ? T["ModerationAccessGranted"]
        : T["ModerationAccessDenied"];

    private string GetSessionFailedHint()
    {
        if (_dashboard is null)
        {
            return T["SessionFailedHint"];
        }

        if (_dashboard.FailedCommandCount > 0)
        {
            return string.Format(T["SessionFailedHintWithCommands"], _dashboard.FailedCommandCount);
        }

        if (_dashboard.LeaseExpiresAtUtc.HasValue)
        {
            return string.Format(T["SessionFailedHintWithLease"], FormatTime(_dashboard.LeaseExpiresAtUtc));
        }

        return T["SessionFailedHint"];
    }

    private string GetStateReasonLabel()
    {
        var reason = _dashboard?.StateReason;
        if (string.IsNullOrWhiteSpace(reason))
        {
            return T["StateReasonUnknown"];
        }

        return reason switch
        {
            "command_path_unstable" => T["StateReasonCommandPathUnstable"],
            "command_path_recovered" => T["StateReasonCommandPathRecovered"],
            "command_timeout" => T["StateReasonCommandTimeout"],
            "command_rejected" => T["StateReasonCommandRejected"],
            "lease_expired" => T["StateReasonLeaseExpired"],
            "lease_recovery_timeout" => T["StateReasonLeaseRecoveryTimeout"],
            "state_reconciled" => T["StateReasonReconciled"],
            _ => reason,
        };
    }

    protected override async Task OnParametersSetAsync()
    {
        EnsureShareRequestDefaults();
        EnsureRecoveryStatePollingStarted();
        await RefreshAsync();
