@inherits LayoutComponentBase
@implements IAsyncDisposable
@inject OperatorText T
@inject OperatorAuthDescriptor Auth
@inject OperatorIdentityContext Identity
@inject NavigationManager Navigation
@inject HidBridge.ControlPlane.Web.Services.ControlPlaneApiClient ApiClient

<div class="hid-shell">
    <div class="hid-shell-frame">
        <aside class="hid-shell-sidebar">
            <NavMenu />
        </aside>

        <main class="hid-shell-main">
            <header class="hid-header-panel hid-card">
                <div class="hid-header-top">
                    <div>
                        <p class="hid-section-kicker">@T["HidBridgeOperatorConsole"]</p>
                        <h1 class="hid-logo hid-header-logo">HIDBRIDGE</h1>
                        <p class="hid-header-subtitle">@T["ControlPlaneWeb"]</p>
                    </div>
                    <div class="hid-header-meta-grid">
                        <div class="hid-header-meta hid-card-soft">
                            <div class="hid-header-meta-label">@T["UiStack"]</div>
                            <div class="hid-header-meta-value">@T["ThinOperatorShell"]</div>
                        </div>
                        <div class="hid-header-meta hid-card-soft">
                            <div class="hid-header-meta-label">@T["DataSource"]</div>
                            <div class="hid-header-meta-value">@T["DashboardProjections"]</div>
                        </div>
                        <div class="hid-header-meta hid-card-soft">
                            <div class="hid-header-meta-label">IDENTITY</div>
                            <div class="hid-header-meta-value">@Identity.DisplayName</div>
                            <div class="hid-meta-note">@Identity.TenantId / @Identity.OrganizationId</div>
                            <div class="hid-meta-note">@Identity.RoleSummary</div>
                        </div>
                        <div class="hid-header-meta hid-card-soft">
                            <div class="hid-header-meta-label">AUTH</div>
                            <div class="hid-header-meta-value">@Auth.ProviderDisplayName</div>
                            <div class="hid-meta-note">@Auth.Mode</div>
                            <div class="hid-meta-note">@Identity.AuthenticationMode</div>
                        </div>
                    </div>
                </div>

                <div class="hid-header-footer">
                    <div>
                        @T["CurrentCulture"]: <span class="hid-list-title">@T.CurrentCultureCode</span>
                    </div>
                    <div class="hid-action-row">
                        <a class="hid-button-secondary hid-button-sm" href="/settings">@T["OpenSettings"]</a>
                        @if (Identity.IsAuthenticated)
                        {
                            <a class="hid-button-ghost hid-button-sm" href="@Auth.LogoutPath">@T["SignOut"]</a>
                        }
                        else
                        {
                            <a class="hid-button-ghost hid-button-sm" href="@Auth.LoginPath">@T["SignIn"]</a>
                        }
                    </div>
                </div>
            </header>

            @if (!_isBackendAvailable)
            {
                <div class="hid-alert hid-alert--danger hid-backend-banner" role="status" aria-live="polite">
                    <div class="hid-backend-banner-title">@T["BackendUnavailable"]</div>
                    <div>@T["BackendMonitorUnavailable"]</div>
                    @if (!string.IsNullOrWhiteSpace(_backendUnavailableDetail))
                    {
                        <div class="hid-backend-banner-detail">@_backendUnavailableDetail</div>
                    }
                </div>
            }

            <article class="hid-content-panel hid-card">
                @Body
            </article>
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private static readonly TimeSpan BackendProbeInterval = TimeSpan.FromSeconds(3);
    private CancellationTokenSource? _backendProbeCts;
    private Task? _backendProbeTask;
    private bool _monitorStarted;
    private bool _isBackendAvailable = true;
    private string? _backendUnavailableDetail;
    private bool _reloadCurrentViewOnRecovery;

    protected override void OnInitialized()
        => StartBackendProbe();

    private void StartBackendProbe()
    {
        if (_monitorStarted)
        {
            return;
        }

        _monitorStarted = true;
        _backendProbeCts = new CancellationTokenSource();
        _backendProbeTask = ProbeLoopAsync(_backendProbeCts.Token);
    }

    private async Task ProbeLoopAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(BackendProbeInterval);
        try
        {
            await ProbeBackendAsync(cancellationToken);
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await ProbeBackendAsync(cancellationToken);
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
            // Expected during layout disposal.
        }
    }

    private async Task ProbeBackendAsync(CancellationToken cancellationToken)
    {
        var wasAvailable = _isBackendAvailable;
        var isAvailable = true;
        string? unavailableDetail = null;

        try
        {
            _ = await ApiClient.GetHealthAsync(cancellationToken);
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
            throw;
        }
        catch (HidBridge.ControlPlane.Web.Services.ControlPlaneApiUnavailableException exception)
        {
            isAvailable = false;
            unavailableDetail = exception.Message;
        }
        catch (HidBridge.ControlPlane.Web.Services.ControlPlaneApiException)
        {
            // Reachable API with auth/validation error still means backend is up.
            isAvailable = true;
        }
        catch (Exception exception)
        {
            isAvailable = false;
            unavailableDetail = exception.Message;
        }

        _isBackendAvailable = isAvailable;
        _backendUnavailableDetail = unavailableDetail;

        if (wasAvailable != _isBackendAvailable)
        {
            if (!_isBackendAvailable)
            {
                _reloadCurrentViewOnRecovery = true;
            }

            await InvokeAsync(StateHasChanged);
        }

        if (_isBackendAvailable && _reloadCurrentViewOnRecovery)
        {
            _reloadCurrentViewOnRecovery = false;
            await InvokeAsync(() => Navigation.NavigateTo(Navigation.Uri, forceLoad: true, replace: true));
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_backendProbeCts is null)
        {
            return;
        }

        _backendProbeCts.Cancel();

        if (_backendProbeTask is not null)
        {
            try
            {
                await _backendProbeTask;
            }
            catch (OperationCanceledException)
            {
                // Expected during disposal.
            }
        }

        _backendProbeCts.Dispose();
        _backendProbeCts = null;
    }
}
