{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ControlPlaneApi": {
    "BaseUrl": "http://127.0.0.1:18093",
    "OperatorPrincipalId": "smoke-runner",
    "PropagateIdentityHeaders": true,
    "PropagateAccessToken": true
  },
  "Identity": {
    "Enabled": false,
    "ProviderDisplayName": "OpenID Connect",
    "Authority": "",
    "ClientId": "",
    "ClientSecret": "",
    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-callback-oidc",
    "RequireHttpsMetadata": false,
    "DisablePushedAuthorization": true,
    "Scopes": [],
    "SubjectClaimType": "sub",
    "PrincipalClaimType": "preferred_username",
    "DisplayNameClaimType": "name",
    "TenantClaimType": "tenant_id",
    "OrganizationClaimType": "org_id",
    "RoleClaimType": "role",
    "Development": {
      "SubjectId": "local-operator",
      "PrincipalId": "smoke-runner",
      "DisplayName": "Local Operator",
      "TenantId": "local-tenant",
      "OrganizationId": "local-org",
      "Roles": [ "operator.viewer", "operator.moderator", "operator.admin" ]
    }
  }
}
