# RuntimeCtl MediaLocal profile (PowerShell: set as $env:VAR=value in current shell).
# This file is documentation template; RuntimeCtl does not auto-load it.

HIDBRIDGE_EDGE_PROXY_MEDIAENGINE=ffmpeg-dcd
HIDBRIDGE_EDGE_PROXY_FFMPEGEXECUTABLEPATH=ffmpeg
HIDBRIDGE_EDGE_PROXY_MEDIAHEALTHURL=http://127.0.0.1:28092/health

# Use one of:
# - HLS/DASH playback URL:
HIDBRIDGE_EDGE_PROXY_MEDIAPLAYBACKURL=http://127.0.0.1:19851/rtc/v1/whep/?app=live&stream=cam21
# - or WHEP endpoint:
HIDBRIDGE_EDGE_PROXY_MEDIAWHEPURL=http://127.0.0.1:19851/rtc/v1/whep/?app=live&stream=cam21
HIDBRIDGE_EDGE_PROXY_MEDIAWHIPURL=http://127.0.0.1:19851/rtc/v1/whip/?app=live&stream=cam21

# Do not mark media ready without actual playback path.
HIDBRIDGE_EDGE_PROXY_ASSUMEMEDIAREADYWITHOUTPROBE=false
HIDBRIDGE_EDGE_PROXY_REQUIREMEDIAREADY=true

# Optional for secured WHIP endpoints (only if WHIP publish is enabled)
# HIDBRIDGE_EDGE_PROXY_MEDIAWHIPBEARERTOKEN=<token>
